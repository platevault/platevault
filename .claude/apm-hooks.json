{
  "PreToolUse": [
    {
      "matcher": "Edit|Write|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/agent-coder/scripts/coder-delegation-reminder.sh",
          "timeout": 3
        }
      ],
      "_apm_source": "agent-coder"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "statusMessage": "Checking gh issue command against beads policy...",
          "command": ".claude/hooks/beads/scripts/beads-gh-issue-guard.sh"
        }
      ],
      "_apm_source": "beads"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/hooks-quality/scripts/quality-before-commit.sh",
          "timeout": 10
        }
      ],
      "_apm_source": "hooks-quality"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/release-please/scripts/release-please-guard.sh",
          "timeout": 10
        }
      ],
      "_apm_source": "release-please"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-pr-title.sh"
        }
      ],
      "_apm_source": "speckit"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "statusMessage": "Checking draft PR and Beads linkage policy...",
          "command": ".claude/hooks/steering-git-workflow/scripts/pr-create-guard.sh",
          "timeout": 10
        }
      ],
      "_apm_source": "steering-git-workflow"
    }
  ],
  "SubagentStart": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "statusMessage": "Injecting beads work contract...",
          "command": ".claude/hooks/beads/scripts/beads-subagent-reminder.sh"
        }
      ],
      "_apm_source": "beads"
    },
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/steering-pragmatic/scripts/inject-working-style.sh",
          "timeout": 5
        }
      ],
      "_apm_source": "steering-pragmatic"
    },
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/code-intelligence/scripts/subagent-context-inject.sh",
          "timeout": 5
        }
      ],
      "_apm_source": "code-intelligence"
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "if": "Bash(git commit*)",
          "command": ".claude/hooks/speckit/scripts/speckit-task-commit-check.sh"
        }
      ],
      "_apm_source": "speckit"
    },
    {
      "matcher": "apply_patch|Edit|Write|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/hooks-quality/scripts/quality-edit-advisory.sh",
          "timeout": 3
        }
      ],
      "_apm_source": "hooks-quality"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
          "timeout": 30
        }
      ],
      "_apm_source": "mcp-repomix"
    }
  ],
  "UserPromptSubmit": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-deferred-issues.sh"
        }
      ],
      "_apm_source": "speckit"
    }
  ],
  "Stop": [
    {
      "matcher": "*",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-stop-gate.sh"
        }
      ],
      "_apm_source": "speckit"
    }
  ]
}
