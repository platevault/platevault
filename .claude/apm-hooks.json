{
  "UserPromptExpansion": [
    {
      "matcher": "speckit.*",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/skills/speckit-dag/scripts/dispatcher.sh",
          "args": [
            "pre"
          ],
          "timeout": 5,
          "statusMessage": "Checking SpecKit DAG preconditions..."
        }
      ],
      "_apm_source": "speckit"
    },
    {
      "matcher": "speckit.*",
      "hooks": [
        {
          "type": "command",
          "command": "python3 .claude/hooks/speckit-dag-hooks/scripts/dispatcher.py .claude/hooks/speckit-dag-hooks/scripts/nodes.json pre",
          "timeout": 5,
          "statusMessage": "Checking SpecKit DAG preconditions..."
        }
      ],
      "_apm_source": "speckit-dag-hooks"
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Edit|Write|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-package-version/scripts/package-file-warn.sh",
          "if": "Edit(Cargo.toml)|Edit(package.json)|Edit(pyproject.toml)|Edit(go.mod)|Edit(Gemfile)|Edit(composer.json)|Write(Cargo.toml)|Write(package.json)|Write(pyproject.toml)|Write(go.mod)|Write(Gemfile)|Write(composer.json)"
        }
      ],
      "_apm_source": "mcp-package-version"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-package-version/scripts/pkg-version-warn.sh",
          "if": "Bash(pnpm add*)|Bash(cargo add*)|Bash(uv add*)|Bash(pip install*)"
        }
      ],
      "_apm_source": "mcp-package-version"
    },
    {
      "matcher": "Edit|Write|MultiEdit",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/agent-coder/scripts/coder-delegation-reminder.sh",
          "timeout": 3
        }
      ],
      "_apm_source": "agent-coder"
    },
    {
      "matcher": "Skill",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-context7-reminder.sh"
        }
      ],
      "_apm_source": "speckit"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-issue-close-guard.sh",
          "if": "Bash(gh issue close*)|Bash(*gh issue close*)|Bash(glab issue close*)"
        },
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-issue-label-guard.sh",
          "if": "Bash(gh issue create*)|Bash(*gh issue create*)|Bash(glab issue create*)|Bash(*glab issue create*)"
        },
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-pr-issue-refs.sh",
          "if": "Bash(gh pr create*)|Bash(*gh pr create*)|Bash(*gh-api.py*pr create*)|Bash(glab mr create*)|Bash(*glab mr create*)"
        }
      ],
      "_apm_source": "speckit"
    },
    {
      "matcher": "Skill",
      "hooks": [
        {
          "type": "command",
          "command": "python3 .claude/hooks/speckit-dag-hooks/scripts/dispatcher.py .claude/hooks/speckit-dag-hooks/scripts/nodes.json pre",
          "timeout": 5,
          "statusMessage": "Checking SpecKit DAG preconditions..."
        }
      ],
      "_apm_source": "speckit-dag-hooks"
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
          "if": "Bash(git switch -c*)|Bash(git switch --create*)|Bash(git checkout -b*)|Bash(git checkout -B*)|Bash(git worktree add*)|Bash(git merge*)|Bash(git pull*)|Bash(git rebase*)",
          "async": true,
          "timeout": 30
        }
      ],
      "_apm_source": "mcp-repomix"
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-task-commit-check.sh",
          "if": "Bash(git commit*)"
        }
      ],
      "_apm_source": "speckit"
    },
    {
      "matcher": "Skill",
      "hooks": [
        {
          "type": "command",
          "command": "python3 .claude/hooks/speckit-dag-hooks/scripts/dispatcher.py .claude/hooks/speckit-dag-hooks/scripts/nodes.json post",
          "timeout": 5,
          "statusMessage": "Loading SpecKit next-step context..."
        }
      ],
      "_apm_source": "speckit-dag-hooks"
    }
  ],
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-deferred-issues.sh"
        }
      ],
      "_apm_source": "speckit"
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": ".claude/hooks/speckit/scripts/speckit-stop-gate.sh"
        }
      ],
      "_apm_source": "speckit"
    }
  ]
}
