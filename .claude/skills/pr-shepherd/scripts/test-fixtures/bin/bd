#!/usr/bin/env bash
set -Eeuo pipefail

: "${FAKE_STATE:?FAKE_STATE is required}"
: "${FAKE_SCENARIO:?FAKE_SCENARIO is required}"
printf '%s\n' "$*" >>"$FAKE_STATE/bd.log"

increment() {
  local file="$1"
  local count=0
  if [[ -f "$file" ]]; then
    read -r count <"$file"
  fi
  count=$((count + 1))
  printf '%s\n' "$count" >"$file"
  printf '%s\n' "$count"
}

readonly WAITER_ROOT="$FAKE_STATE/waiters"
mkdir -p "$WAITER_ROOT"

waiter_id_for() {
  local holder="$1"
  local generation="${2:-1}"
  local digest

  digest="$(printf 'slot-1\0%s\0%s\0' "$holder" "$generation" | sha1sum | awk '{print $1}')"
  printf 'slot-1-waiter-%s\n' "${digest:0:12}"
}

native_holder_for() {
  local holder="$1"
  local generation="${2:-1}"
  local lease_actor="${3:-actor-a}"
  local waiter digest

  waiter="$(waiter_id_for "$holder" "$generation")"
  digest="$(printf '%s\0%s\0%s\0%s\0' "$holder" "$generation" "$lease_actor" "$waiter" |
    git hash-object --stdin)"
  printf 'pr-shepherd:%s\n' "$digest"
}

seed_waiter() {
  local holder="$1"
  local status="${2:-open}"
  local created="${3:-}"
  local generation="${4:-1}"
  local lease_actor="${5:-actor-a}"
  local linked="${6:-true}"
  local waiter record

  waiter="$(waiter_id_for "$holder" "$generation")"
  record="$WAITER_ROOT/$waiter"
  [[ ! -d "$record" ]] || return 0
  mkdir -p "$record"
  if [[ -z "$created" ]]; then
    created="$(increment "$FAKE_STATE/waiter-created-count")"
  fi
  printf '%s\n' "$holder" >"$record/holder"
  printf '%s\n' "$status" >"$record/status"
  printf '%s\n' "$generation" >"$record/generation"
  printf '%s\n' "$lease_actor" >"$record/lease-actor"
  printf '%s\n' "$linked" >"$record/linked"
  if [[ "$status" == "in_progress" ]]; then
    printf '%s\n' "$lease_actor" >"$record/assignee"
  else
    : >"$record/assignee"
  fi
  printf '2026-01-01T00:00:%02dZ\n' "$created" >"$record/created"
}

seed_scenario_waiters() {
  case "$FAKE_SCENARIO" in
  slot-fairness) seed_waiter earlier-holder open 0 ;;
  slot-fairness-tie)
    seed_waiter tie-a open 0
    seed_waiter tie-b open 0
    ;;
  recover-slot*) seed_waiter dead-holder in_progress 1 ;;
  recover-waiter*) seed_waiter dead-waiter open 1 ;;
  recover-claim-waiter*) seed_waiter stable-holder in_progress 1 1 dead-actor ;;
  slot-wrong-link) seed_waiter stable-holder open 1 1 actor-a wrong:slot-other ;;
  esac
}

emit_waiters() {
  local id_filter="$1"
  local status_filter="$2"
  local holder_filter="$3"
  local record id holder status created generation lease_actor assignee linked dependencies

  {
    for record in "$WAITER_ROOT"/*; do
      [[ -d "$record" ]] || continue
      id="${record##*/}"
      holder="$(<"$record/holder")"
      status="$(<"$record/status")"
      created="$(<"$record/created")"
      generation="$(<"$record/generation")"
      lease_actor="$(<"$record/lease-actor")"
      assignee="$(<"$record/assignee")"
      linked="$(<"$record/linked")"
      [[ -z "$id_filter" || "$id" == "$id_filter" ]] || continue
      [[ -z "$status_filter" || ",$status_filter," == *",$status,"* ]] || continue
      [[ -z "$holder_filter" || "$holder" == "$holder_filter" ]] || continue
      dependencies='[]'
      if [[ "$linked" == "true" ]]; then
        dependencies='[{"issue_id":"'"$id"'","depends_on_id":"slot-1","type":"parent-child"}]'
      elif [[ "$linked" == wrong:* ]]; then
        dependencies='[{"issue_id":"'"$id"'","depends_on_id":"'"${linked#wrong:}"'","type":"parent-child"}]'
      fi
      jq -cn --arg id "$id" --arg holder "$holder" --arg status "$status" \
        --arg created "$created" --arg actor "$lease_actor" --arg assignee "$assignee" \
        --argjson generation "$generation" --argjson dependencies "$dependencies" \
        '{id: $id, status: $status, assignee: $assignee, created_at: $created,
          metadata: {slot_id: "slot-1", holder: $holder, lease_actor: $actor,
            generation: $generation, waiter_id: $id}, dependencies: $dependencies}'
    done
  } | jq -s '.'
}

if [[ "${1:-}" == "merge-slot" && "${2:-}" == "create" ]]; then
  exit 0
fi

if [[ "${1:-}" == "merge-slot" && "${2:-}" == "check" ]]; then
  if [[ -f "$FAKE_STATE/acquired" && ! -f "$FAKE_STATE/released" ]]; then
    holder="$(<"$FAKE_STATE/holder")"
    printf '{"available":false,"holder":"%s","id":"slot-1","waiters":null}\n' "$holder"
    exit 0
  fi
  case "$FAKE_SCENARIO" in
  slot-contention)
    check_count="$(increment "$FAKE_STATE/check-count")"
    if [[ "$check_count" -eq 1 ]]; then
      printf '{"available":false,"holder":"other","id":"slot-1","waiters":null}\n'
    else
      printf '{"available":true,"holder":null,"id":"slot-1","waiters":null}\n'
    fi
    ;;
  slot-fairness*)
    printf '{"available":true,"holder":null,"id":"slot-1","waiters":null}\n'
    ;;
  slot-queued-restart)
    if [[ -f "$FAKE_STATE/make-available" ]]; then
      printf '{"available":true,"holder":null,"id":"slot-1","waiters":null}\n'
    elif [[ -f "$FAKE_STATE/queued" ]]; then
      printf '{"available":false,"holder":"other","id":"slot-1","waiters":null}\n'
    else
      printf '{"available":false,"holder":"other","id":"slot-1","waiters":null}\n'
    fi
    ;;
  slot-restart | slot-failure | land-restart | land-waiting | land-release-failure)
    if [[ "$FAKE_SCENARIO" == "slot-restart" ]]; then
      printf '{"available":false,"holder":"%s","id":"slot-1","waiters":null}\n' \
        "$(native_holder_for stable-holder)"
    else
      printf '{"available":true,"holder":null,"id":"slot-1","waiters":null}\n'
    fi
    ;;
  recover-slot*)
    if [[ -f "$FAKE_STATE/successor" ]]; then
      printf '{"available":false,"holder":"%s","id":"slot-1","waiters":null}\n' \
        "$(native_holder_for successor)"
    elif [[ -f "$FAKE_STATE/released" ]]; then
      printf '{"available":true,"holder":null,"id":"slot-1","waiters":null}\n'
    else
      printf '{"available":false,"holder":"%s","id":"slot-1","waiters":null}\n' \
        "$(native_holder_for dead-holder)"
    fi
    ;;
  recover-waiter*)
    if [[ -f "$FAKE_STATE/concurrent-holder" ]]; then
      printf '{"available":false,"holder":"successor","id":"slot-1","waiters":null}\n'
    else
      printf '{"available":true,"holder":null,"id":"slot-1","waiters":null}\n'
    fi
    ;;
  recover-claim-waiter*)
    if [[ -f "$FAKE_STATE/released" ]]; then
      printf '{"available":true,"holder":null,"id":"slot-1","waiters":null}\n'
    else
      printf '{"available":false,"holder":"%s","id":"slot-1","waiters":null}\n' \
        "$(native_holder_for stable-holder 1 dead-actor)"
    fi
    ;;
  *)
    printf '{"available":true,"holder":null,"id":"slot-1","waiters":null}\n'
    ;;
  esac
  exit 0
fi

if [[ "${1:-}" == "merge-slot" && "${2:-}" == "acquire" ]]; then
  if [[ "$FAKE_SCENARIO" == "recover-claim-waiter-competitor-before-acquire" &&
    "${BEADS_ACTOR:-}" == "actor-c" && ! -f "$FAKE_STATE/acquire-blocked" ]]; then
    touch "$FAKE_STATE/acquire-blocked"
    exit 1
  fi
  if [[ "$FAKE_SCENARIO" == "slot-record-holder-race" &&
    ! -f "$FAKE_STATE/concurrent-holder" ]]; then
    seed_waiter successor in_progress
    printf '%s\n' successor >"$FAKE_STATE/holder"
    touch "$FAKE_STATE/acquired" "$FAKE_STATE/concurrent-holder"
    exit 1
  fi
  if [[ "$FAKE_SCENARIO" == "slot-record-eligibility-interleave" &&
    ! -f "$FAKE_STATE/concurrent-waiter" ]]; then
    seed_waiter later-holder open
    touch "$FAKE_STATE/concurrent-waiter"
  fi
  previous=""
  for argument in "$@"; do
    if [[ "$previous" == "--holder" ]]; then
      printf '%s\n' "$argument" >"$FAKE_STATE/holder"
      break
    fi
    previous="$argument"
  done
  rm -f "$FAKE_STATE/released"
  touch "$FAKE_STATE/acquired"
  exit 0
fi

if [[ "${1:-}" == "merge-slot" && "${2:-}" == "release" ]]; then
  if [[ "$FAKE_SCENARIO" == "land-release-failure" ]]; then
    exit 1
  fi
  requested_holder=""
  previous=""
  for argument in "$@"; do
    [[ "$previous" != "--holder" ]] || requested_holder="$argument"
    previous="$argument"
  done
  if [[ "$FAKE_SCENARIO" == "recover-claim-waiter-delayed-loser" &&
    ! -f "$FAKE_STATE/winner-interleaved" ]]; then
    dead_waiter="$(waiter_id_for stable-holder 1)"
    printf 'closed\n' >"$WAITER_ROOT/$dead_waiter/status"
    seed_waiter stable-holder in_progress "" 2 actor-c
    printf '%s\n' "$(native_holder_for stable-holder 2 actor-c)" >"$FAKE_STATE/holder"
    touch "$FAKE_STATE/acquired" "$FAKE_STATE/winner-interleaved"
    exit 1
  fi
  if [[ "$FAKE_SCENARIO" == "recover-claim-waiter-release-before-close" &&
    ! -f "$FAKE_STATE/winner-interleaved" ]]; then
    dead_waiter="$(waiter_id_for stable-holder 1)"
    printf 'closed\n' >"$WAITER_ROOT/$dead_waiter/status"
    seed_waiter stable-holder in_progress "" 2 actor-c
    printf '%s\n' "$(native_holder_for stable-holder 2 actor-c)" >"$FAKE_STATE/holder"
    printf 'actor-c\n' >"$FAKE_STATE/claim-assignee"
    printf 'in_progress\n' >"$FAKE_STATE/claim-status"
    printf 'winner-receipt\n' >"$FAKE_STATE/recovery-key"
    printf 'complete\n' >"$FAKE_STATE/recovery-phase"
    touch "$FAKE_STATE/acquired" "$FAKE_STATE/winner-interleaved"
    exit 0
  fi
  if [[ -f "$FAKE_STATE/acquired" && ! -f "$FAKE_STATE/released" &&
    "$requested_holder" != "$(<"$FAKE_STATE/holder")" ]]; then
    exit 1
  fi
  touch "$FAKE_STATE/released"
  exit 0
fi

if [[ "${1:-}" == "ready" ]]; then
  printf '[{"id":"merge-second"},{"id":"merge-first"}]\n'
  exit 0
fi

if [[ "${1:-}" == "list" ]]; then
  id_filter=""
  status_filter=""
  holder_filter=""
  waiter_query=false
  previous=""
  for argument in "$@"; do
    [[ "$previous" != "--id" ]] || id_filter="$argument"
    [[ "$previous" != "--status" ]] || status_filter="$argument"
    if [[ "$previous" == "--metadata-field" && "$argument" == holder=* ]]; then
      holder_filter="${argument#holder=}"
    fi
    if [[ "$previous" == "--parent" ||
      ("$previous" == "--label" && "$argument" == "gt:slot-waiter") ]]; then
      waiter_query=true
    fi
    previous="$argument"
  done
  if [[ -n "$id_filter" || "$waiter_query" == "true" ]]; then
    seed_scenario_waiters
    emit_waiters "$id_filter" "$status_filter" "$holder_filter"
  elif [[ "$FAKE_SCENARIO" == "bounce-preexisting-duplicates" ]]; then
    if [[ -f "$FAKE_STATE/closed-fix-newer" ]]; then
      printf '[{"id":"fix-oldest","created_at":"2026-01-01T00:00:00Z"}]\n'
    else
      printf '[{"id":"fix-newer","created_at":"2026-01-02T00:00:00Z"},{"id":"fix-oldest","created_at":"2026-01-01T00:00:00Z"}]\n'
    fi
  elif [[ "$FAKE_SCENARIO" == "duplicate-bounce" || "$FAKE_SCENARIO" == bounce-crash-* ||
    "$FAKE_SCENARIO" == bounce-*-query-error ]]; then
    printf '[{"id":"fix-1","created_at":"2026-01-01T00:00:00Z"}]\n'
  else
    printf '[]\n'
  fi
  exit 0
fi

if [[ "${1:-}" == "show" ]]; then
  if [[ "${2:-}" == "slot-1" ]]; then
    holder="stable-holder"
    if [[ -f "$FAKE_STATE/holder" ]]; then
      holder="$(<"$FAKE_STATE/holder")"
    fi
    printf '[{"id":"slot-1","metadata":{"holder":"%s","waiters":[]}}]\n' "$holder"
  else
    if [[ "$FAKE_SCENARIO" == "bounce-receipt-query-error" ||
      "$FAKE_SCENARIO" == "recover-receipt-query-error" ]]; then
      exit 88
    fi
    if [[ "$FAKE_SCENARIO" == "bounce-dependency-query-error" &&
      -f "$FAKE_STATE/bounce-phase" && "$(<"$FAKE_STATE/bounce-phase")" == "fix_ready" ]]; then
      exit 88
    fi
    dependency_json='[]'
    if [[ -f "$FAKE_STATE/dependency" ]]; then
      dependency_target="fix-1"
      [[ ! -f "$FAKE_STATE/dependency-target" ]] || dependency_target="$(<"$FAKE_STATE/dependency-target")"
      dependency_json="[{\"id\":\"$dependency_target\"}]"
    fi
    bounce_key=""
    bounce_fix=""
    bounce_phase=""
    recovery_key=""
    recovery_phase=""
    assignee=""
    status="open"
    labels='[]'
    [[ ! -f "$FAKE_STATE/bounce-key" ]] || bounce_key="$(<"$FAKE_STATE/bounce-key")"
    [[ ! -f "$FAKE_STATE/bounce-fix" ]] || bounce_fix="$(<"$FAKE_STATE/bounce-fix")"
    [[ ! -f "$FAKE_STATE/bounce-phase" ]] || bounce_phase="$(<"$FAKE_STATE/bounce-phase")"
    [[ ! -f "$FAKE_STATE/recovery-key" ]] || recovery_key="$(<"$FAKE_STATE/recovery-key")"
    [[ ! -f "$FAKE_STATE/recovery-phase" ]] || recovery_phase="$(<"$FAKE_STATE/recovery-phase")"
    if [[ -s "$FAKE_STATE/claim-assignee" ]]; then
      assignee="$(<"$FAKE_STATE/claim-assignee")"
      status="$(<"$FAKE_STATE/claim-status")"
      [[ "$status" != "in_progress" ]] || labels='["agent:integrator","state:working"]'
    elif [[ "$FAKE_SCENARIO" == recover-claim* && -f "$FAKE_STATE/successor" ]]; then
      assignee="successor"
      status="in_progress"
      labels='["agent:integrator","state:working"]'
    elif [[ "$FAKE_SCENARIO" == recover-claim* && ! -f "$FAKE_STATE/claim-released" ]]; then
      assignee="dead-actor"
      status="in_progress"
      labels='["agent:integrator","state:working"]'
    fi
    printf '[{"id":"merge-1","assignee":"%s","status":"%s","labels":%s,"metadata":{"bounce_key":"%s","bounce_fix":"%s","bounce_phase":"%s","recovery_key":"%s","recovery_phase":"%s"},"dependencies":%s}]\n' \
      "$assignee" "$status" "$labels" "$bounce_key" "$bounce_fix" "$bounce_phase" "$recovery_key" "$recovery_phase" "$dependency_json"
  fi
  exit 0
fi

if [[ "${1:-}" == "dep" && "${2:-}" == "add" ]]; then
  if [[ -d "$WAITER_ROOT/${3:-}" && "${4:-}" == "slot-1" ]]; then
    if [[ "$FAKE_SCENARIO" == "slot-link-crash" && ! -f "$FAKE_STATE/link-failed" ]]; then
      touch "$FAKE_STATE/link-failed"
      exit 91
    fi
    printf 'true\n' >"$WAITER_ROOT/${3}/linked"
    exit 0
  fi
  if [[ "$FAKE_SCENARIO" == "bounce-crash-dep" && ! -f "$FAKE_STATE/dep-failed" ]]; then
    touch "$FAKE_STATE/dep-failed"
    exit 91
  fi
  touch "$FAKE_STATE/dependency"
  printf '%s\n' "${4:-fix-1}" >"$FAKE_STATE/dependency-target"
  exit 0
fi

if [[ "${1:-}" == "create" ]]; then
  waiter=""
  metadata=""
  previous=""
  for argument in "$@"; do
    [[ "$previous" != "--id" ]] || waiter="$argument"
    [[ "$previous" != "--metadata" ]] || metadata="$argument"
    previous="$argument"
  done
  if [[ -n "$waiter" ]]; then
    holder="$(printf '%s' "$metadata" | jq -er '.holder')" || exit 89
    generation="$(printf '%s' "$metadata" | jq -er '.generation')" || exit 89
    lease_actor="$(printf '%s' "$metadata" | jq -er '.lease_actor')" || exit 89
    [[ "$(printf '%s' "$metadata" | jq -r '.slot_id')" == "slot-1" ]] || exit 89
    [[ "$(printf '%s' "$metadata" | jq -r '.waiter_id')" == "$waiter" ]] || exit 89
    [[ "$waiter" == "$(waiter_id_for "$holder" "$generation")" ]] || exit 89
    [[ ! -d "$WAITER_ROOT/$waiter" ]] || exit 1
    seed_waiter "$holder" open "" "$generation" "$lease_actor" false
    touch "$FAKE_STATE/waiter-created"
    printf '%s\n' "$waiter"
  else
    touch "$FAKE_STATE/created"
    printf 'fix-new\n'
  fi
  exit 0
fi

case "${1:-}" in
close)
  if [[ -d "$WAITER_ROOT/${2:-}" ]]; then
    if [[ "$FAKE_SCENARIO" == "recover-waiter-successor-interleave" &&
      ! -f "$FAKE_STATE/concurrent-state-preserved" ]]; then
      seed_waiter successor in_progress
      seed_waiter concurrent-waiter open
      touch "$FAKE_STATE/concurrent-holder" "$FAKE_STATE/concurrent-state-preserved"
    elif [[ "$FAKE_SCENARIO" == "slot-record-close-interleave" &&
      ! -f "$FAKE_STATE/concurrent-state-preserved" ]]; then
      seed_waiter later-holder open
      touch "$FAKE_STATE/concurrent-state-preserved"
    fi
    printf 'closed\n' >"$WAITER_ROOT/${2}/status"
    touch "$FAKE_STATE/waiter-cleaned"
    exit 0
  fi
  if [[ "$FAKE_SCENARIO" == "land-restart" && ! -f "$FAKE_STATE/released" ]]; then
    printf 'close happened before slot release\n' >&2
    exit 98
  fi
  if [[ -n "${2:-}" ]]; then
    touch "$FAKE_STATE/closed-${2}"
  fi
  exit 0
  ;;
comments)
  issue="${2:-}"
  if [[ "$FAKE_SCENARIO" == "bounce-comment-query-error" ||
    "$FAKE_SCENARIO" == "recover-comment-query-error" ]]; then
    exit 88
  fi
  if [[ "$issue" == "merge-1" && -f "$FAKE_STATE/bounce-comment-merge" ]]; then
    printf '[{"text":"BOUNCED bounce_receipt=key-1"}]\n'
  elif [[ "$issue" == fix-* && -f "$FAKE_STATE/bounce-comment-fix" ]]; then
    printf '[{"text":"CORRELATED bounce_receipt=key-1"}]\n'
  elif [[ "$issue" == "merge-1" && -f "$FAKE_STATE/recovery-comment" ]]; then
    jq -cn --arg text "$(<"$FAKE_STATE/recovery-comment")" '[{text: $text}]'
  else
    printf '[]\n'
  fi
  exit 0
  ;;
comment)
  if [[ "$*" == *"BOUNCED bounce_receipt="* ]]; then
    touch "$FAKE_STATE/bounce-comment-merge"
  elif [[ "$*" == *"CORRELATED bounce_receipt="* ]]; then
    if [[ "$FAKE_SCENARIO" == "bounce-crash-comment" && ! -f "$FAKE_STATE/comment-failed" ]]; then
      touch "$FAKE_STATE/comment-failed"
      exit 92
    fi
    touch "$FAKE_STATE/bounce-comment-fix"
    increment "$FAKE_STATE/bounce-fix-comment-count" >/dev/null
  elif [[ "$*" == *"RECOVERED recovery_receipt="* ]]; then
    printf '%s\n' "${3:-}" >"$FAKE_STATE/recovery-comment"
  fi
  exit 0
  ;;
update)
  if [[ -d "$WAITER_ROOT/${2:-}" && "$*" == *"--claim"* ]]; then
    if [[ "$FAKE_SCENARIO" == "slot-cleanup-failure" ]]; then
      exit 93
    fi
    if [[ "$FAKE_SCENARIO" == "slot-cleanup-signal" ]]; then
      kill -TERM "$PPID"
      exit 94
    fi
    [[ "$(<"$WAITER_ROOT/${2}/status")" != "closed" ]] || exit 1
    printf 'in_progress\n' >"$WAITER_ROOT/${2}/status"
    printf '%s\n' "${BEADS_ACTOR:-}" >"$WAITER_ROOT/${2}/assignee"
    touch "$FAKE_STATE/waiter-claimed"
    exit 0
  fi
  if [[ -d "$WAITER_ROOT/${2:-}" ]]; then
    transferred=false
    previous=""
    for argument in "$@"; do
      if [[ "$previous" == "--assignee" ]]; then
        printf '%s\n' "$argument" >"$WAITER_ROOT/${2}/assignee"
      elif [[ "$previous" == "--status" ]]; then
        printf '%s\n' "$argument" >"$WAITER_ROOT/${2}/status"
      elif [[ "$previous" == "--set-metadata" && "$argument" == lease_actor=* ]]; then
        printf '%s\n' "${argument#lease_actor=}" >"$WAITER_ROOT/${2}/lease-actor"
        transferred=true
      fi
      previous="$argument"
    done
    if [[ "$transferred" == "true" &&
      "$FAKE_SCENARIO" == "recover-claim-waiter-crash-transfer" &&
      ! -f "$FAKE_STATE/waiter-transfer-failed" ]]; then
      touch "$FAKE_STATE/waiter-transfer-failed"
      exit 95
    fi
    exit 0
  fi
  if [[ "${2:-}" == "slot-1" && "$*" == *"--metadata"* ]]; then
    printf 'shared slot metadata rewrite is forbidden\n' >&2
    exit 89
  fi
  if [[ "${2:-}" == "merge-1" && "$*" == *"--assignee  --status open"* ]]; then
    touch "$FAKE_STATE/claim-released"
    : >"$FAKE_STATE/claim-assignee"
    printf 'open\n' >"$FAKE_STATE/claim-status"
  fi
  if [[ "${2:-}" == "merge-1" && "$*" == *"--claim"* ]]; then
    [[ ! -s "$FAKE_STATE/claim-assignee" ]] || exit 1
    printf '%s\n' "${BEADS_ACTOR:-}" >"$FAKE_STATE/claim-assignee"
    printf 'in_progress\n' >"$FAKE_STATE/claim-status"
  fi
  previous=""
  for argument in "$@"; do
    if [[ "$previous" == "--set-metadata" ]]; then
      case "$argument" in
      bounce_key=*) printf '%s\n' "${argument#bounce_key=}" >"$FAKE_STATE/bounce-key" ;;
      bounce_fix=*) printf '%s\n' "${argument#bounce_fix=}" >"$FAKE_STATE/bounce-fix" ;;
      bounce_phase=*) printf '%s\n' "${argument#bounce_phase=}" >"$FAKE_STATE/bounce-phase" ;;
      recovery_key=*) printf '%s\n' "${argument#recovery_key=}" >"$FAKE_STATE/recovery-key" ;;
      recovery_phase=*)
        recovery_phase="${argument#recovery_phase=}"
        if [[ "$recovery_phase" == "mutated" &&
          ("$FAKE_SCENARIO" == recover-*-crash-mutation || "$FAKE_SCENARIO" == recover-*-successor) &&
          ! -f "$FAKE_STATE/mutated-phase-failed" ]]; then
          touch "$FAKE_STATE/mutated-phase-failed"
          exit 95
        fi
        if [[ "$recovery_phase" == "commented" && "$FAKE_SCENARIO" == "recover-slot-crash-comment" &&
          ! -f "$FAKE_STATE/commented-phase-failed" ]]; then
          touch "$FAKE_STATE/commented-phase-failed"
          exit 96
        fi
        if [[ "$recovery_phase" == "audited" && "$FAKE_SCENARIO" == "recover-slot-crash-audit" &&
          ! -f "$FAKE_STATE/audited-phase-failed" ]]; then
          touch "$FAKE_STATE/audited-phase-failed"
          exit 97
        fi
        printf '%s\n' "$recovery_phase" >"$FAKE_STATE/recovery-phase"
        ;;
      esac
    fi
    previous="$argument"
  done
  exit 0
  ;;
audit)
  if [[ "${2:-}" == "record" ]]; then
    tool_name=""
    issue_id=""
    previous=""
    for argument in "$@"; do
      [[ "$previous" != "--tool-name" ]] || tool_name="$argument"
      [[ "$previous" != "--issue-id" ]] || issue_id="$argument"
      previous="$argument"
    done
    printf '{"kind":"tool_call","tool_name":"%s","issue_id":"%s"}\n' \
      "$tool_name" "$issue_id" >>"$FAKE_STATE/interactions.jsonl"
  fi
  exit 0
  ;;
where)
  if [[ "$FAKE_SCENARIO" == "recover-audit-query-error" ]]; then
    exit 88
  fi
  printf '{"path":"%s"}\n' "$FAKE_STATE"
  exit 0
  ;;
esac

printf 'unexpected fake bd invocation: %s\n' "$*" >&2
exit 99
