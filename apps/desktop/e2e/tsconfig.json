{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true
  },
  "include": [
    "./playwright.real-backend.config.ts",
    "./real-backend/**/*.ts"
  ],
  "exclude": ["node_modules", "./helpers"]
}
