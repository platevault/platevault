{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Astro Library Manager",
  "version": "0.1.0",
  "identifier": "dev.astro-plan.astro-library-manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter @astro-plan/desktop dev",
    "beforeBuildCommand": "pnpm --filter @astro-plan/desktop build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Astro Library Manager",
        "width": 1280,
        "height": 820,
        "minWidth": 1280,
        "minHeight": 800
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
