{
  "name": "@astro-plan/desktop",
  "private": true,
  "version": "0.6.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "pretest": "pnpm i18n:compile",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:real": "bash scripts/run-e2e-real.sh",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.e2e.json --noEmit",
    "lint": "biome check . && node ../../scripts/check-eslint-baseline.mjs && node scripts/build-tokens.mjs --check && bash ../../scripts/check-tokens.sh && node ../../scripts/check-i18n-catalog.mjs && node ../../scripts/check-mock-baseline.mjs && node ../../scripts/check-i18n-locale-drift.mjs",
    "lint:biome": "biome check .",
    "lint:eslint": "node ../../scripts/check-eslint-baseline.mjs",
    "lint:mocks": "node ../../scripts/check-mock-baseline.mjs",
    "lint:eslint:raw": "eslint src/",
    "lint:i18n-catalog": "node ../../scripts/check-i18n-catalog.mjs",
    "lint:i18n-drift": "node ../../scripts/check-i18n-locale-drift.mjs",
    "check:tokens": "bash ../../scripts/check-tokens.sh",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "tokens:build": "node scripts/build-tokens.mjs",
    "tokens:check": "node scripts/build-tokens.mjs --check",
    "tokens:types": "node scripts/gen-token-types.mjs",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy custom-almSettings preferredLanguage baseLocale --emit-ts-declarations",
    "pretypecheck": "pnpm i18n:compile",
    "knip": "knip",
    "madge:circular": "madge --circular --extensions ts,tsx src",
    "css:dup-sniff": "node scripts/css-dup-sniff.mjs",
    "size": "size-limit",
    "icons:generate": "node scripts/generate-app-icons.mjs",
    "wordmark:generate": "node scripts/generate-splash-wordmark.mjs",
    "og:generate": "node scripts/generate-og-image.mjs",
    "lockup:generate": "node scripts/generate-lockup.mjs"
  },
  "dependencies": {
    "@base-ui-components/react": "1.0.0-rc.0",
    "@hookform/resolvers": "5.4.0",
    "@inlang/paraglide-js": "^2.21.0",
    "@tanstack/react-query": "5.101.2",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-virtual": "3.14.5",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@visx/group": "^4.0.0",
    "@visx/scale": "^4.0.0",
    "@visx/shape": "^4.0.0",
    "@visx/threshold": "^4.0.0",
    "astronomy-engine": "2.1.19",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "lucide-react": "1.24.0",
    "maplibre-gl": "^5.24.0",
    "pathe": "2.0.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "7.81.0",
    "react-joyride": "^3.2.0",
    "tinykeys": "4.0.0",
    "use-debounce": "10.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.5",
    "@fontsource/space-grotesk": "^5.3.0",
    "@playwright/test": "^1.61.1",
    "@size-limit/file": "^12.1.0",
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "fontkit": "^2.0.4",
    "jsdom": "^29.1.1",
    "knip": "^6.26.0",
    "madge": "^8.0.0",
    "png-to-ico": "^3.0.2",
    "png2icons": "^2.0.1",
    "sharp": "^0.35.3",
    "size-limit": "^12.1.0",
    "style-dictionary": "^5.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.2.0",
    "vitest": "^4.1.10"
  }
}
