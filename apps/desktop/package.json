{
  "name": "@astro-plan/desktop",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "pretest": "pnpm i18n:compile",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ && bash ../../scripts/check-tokens.sh",
    "lint:eslint": "eslint src/",
    "check:tokens": "bash ../../scripts/check-tokens.sh",
    "tokens:types": "node scripts/gen-token-types.mjs",
    "i18n:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/paraglide --strategy baseLocale --emit-ts-declarations",
    "pretypecheck": "pnpm i18n:compile",
    "knip": "knip",
    "madge:circular": "madge --circular --extensions ts,tsx src",
    "size": "size-limit"
  },
  "dependencies": {
    "@astro-plan/contracts": "workspace:*",
    "@base-ui-components/react": "1.0.0-rc.0",
    "@hookform/resolvers": "5.4.0",
    "@inlang/paraglide-js": "^2.20.1",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.169.2",
    "@tanstack/react-table": "8.21.3",
    "@tanstack/react-virtual": "3.13.2",
    "@tauri-apps/api": "^2.9.0",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "lucide-react": "1.14.0",
    "pathe": "2.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-hook-form": "7.80.0",
    "react-joyride": "^3.1.0",
    "react-resizable-panels": "4.11.1",
    "tinykeys": "4.0.0",
    "use-debounce": "10.1.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@tauri-apps/cli": "^2.9.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.61.0",
    "vite": "^7.2.0",
    "vitest": "^4.1.7",
    "knip": "^6.24.0",
    "madge": "^8.0.0",
    "size-limit": "^12.1.0",
    "@size-limit/file": "^12.1.0"
  }
}
