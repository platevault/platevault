# Exclude shell scripts and agent/SpecKit tooling scaffolding from GitHub
# language statistics (linguist) — small Rust crates otherwise report Shell
# as the primary repository language.
*.sh linguist-detectable=false
.specify/** linguist-vendored
.codex/** linguist-vendored
.claude/** linguist-vendored

# Force LF for Biome-formatted frontend sources regardless of platform
# autocrlf. Biome's formatter normalizes to LF (formatter.lineEnding
# default); Windows checkouts otherwise convert to CRLF on the fly and
# every file trips `biome format --check` there only (blobs stay LF).
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.jsx text eol=lf
