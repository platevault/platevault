{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/sourceview.verify.json",
  "title": "sourceview.verify",
  "description": "Read-only verification that every link in a generated source view still resolves to a present canonical source. Reports every broken, missing, or stale item before an expensive processing run. MUST NOT mutate the filesystem and MUST NOT auto-repair (FR-014/FR-015); repair is via explicit spec 026 regeneration. Leans on spec 026 stale detection, framed as an explicit pre-processing check.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "viewId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" },
        "viewId": {
          "type": "string",
          "format": "uuid",
          "description": "Identifier of the PreparedSourceView to verify."
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "clean", "brokenItems"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "clean": {
              "type": "boolean",
              "description": "True when every source resolves to a present canonical file (safe to process, 0 false alarms — SC-006)."
            },
            "brokenItems": {
              "type": "array",
              "description": "Empty when clean. One entry per broken/missing/stale item; reported without any mutation.",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["inventoryItemId", "viewRelativePath", "state"],
                "properties": {
                  "inventoryItemId": { "type": "string", "format": "uuid" },
                  "viewRelativePath": { "type": "string" },
                  "state": {
                    "type": "string",
                    "enum": ["missing", "moved", "unresolved_link", "changed_kind", "hash_diverged"],
                    "description": "Why the item failed verification. Repair is via spec 026 regeneration, never auto-repair here."
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["view.not_found"]
        },
        "message": { "type": "string" }
      }
    }
  }
}
