{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/catalog.entry-file.json",
  "title": "catalog.entry-file",
  "description": "Per-catalog <slug>.json entry file installed by catalog.download. Ratified in spec 033 F3 (specs/tiny/catalog-entry-file-format.md). Single JSON document; coordinates are sexagesimal (RA in hours, Dec in degrees); cross-catalog equivalences are carried inline. Source of spec 013 CatalogRef rows. Wire casing is camelCase, consistent with the contract DTOs.",
  "type": "object",
  "$ref": "#/$defs/CatalogEntryFile",
  "$defs": {
    "CatalogId": {
      "type": "string",
      "enum": ["messier", "caldwell", "sharpless", "abell_pn", "abell_galaxies", "arp", "vdb", "barnard", "lbn", "ldn", "melotte", "common", "openngc"],
      "description": "Closed v1 catalog slug set (spec 013 CatalogId / D3)."
    },
    "ObjectType": {
      "type": "string",
      "enum": ["galaxy", "planetary_nebula", "emission_nebula", "reflection_nebula", "dark_nebula", "open_cluster", "globular_cluster", "supernova_remnant", "galaxy_cluster", "double_star", "asterism", "other"],
      "description": "Closed object-type taxonomy. Unrecognised source types deserialize to 'other' (forward-compat)."
    },
    "RightAscension": {
      "type": "string",
      "pattern": "^([01][0-9]|2[0-3]) [0-5][0-9] [0-5][0-9](\\.[0-9]+)?$",
      "description": "Sexagesimal hours 'HH MM SS.sss' (00-23 h, 00-59 m, 00-59 s)."
    },
    "Declination": {
      "type": "string",
      "pattern": "^[+-]?(0[0-9]|[1-8][0-9]|90) [0-5][0-9] [0-5][0-9](\\.[0-9]+)?$",
      "description": "Sexagesimal degrees '+-DD MM SS.ss' (00-90 deg). At exactly 90 deg the reader requires zero arcmin/arcsec."
    },
    "CatalogEntryEquivalent": {
      "type": "object",
      "description": "An inline cross-catalog equivalence (seeds spec 013 CatalogEquivalence).",
      "required": ["catalogId", "designation"],
      "additionalProperties": false,
      "properties": {
        "catalogId": { "$ref": "#/$defs/CatalogId" },
        "designation": { "type": "string", "minLength": 1 }
      }
    },
    "CatalogEntry": {
      "type": "object",
      "description": "One catalog entry (spec 013 CatalogRef source).",
      "required": ["designation", "names", "ra", "dec", "type"],
      "additionalProperties": false,
      "properties": {
        "designation": { "type": "string", "minLength": 1, "description": "Catalog-local designation, e.g. 'NGC 224'." },
        "names": { "type": "array", "items": { "type": "string" }, "description": "Alternate names / aliases for query matching." },
        "ra": { "$ref": "#/$defs/RightAscension" },
        "dec": { "$ref": "#/$defs/Declination" },
        "type": { "$ref": "#/$defs/ObjectType" },
        "constellation": { "type": "string", "description": "IAU constellation abbreviation, e.g. 'And'." },
        "magnitude": { "type": "number", "description": "Apparent magnitude." },
        "equivalents": { "type": "array", "items": { "$ref": "#/$defs/CatalogEntryEquivalent" } }
      }
    },
    "CatalogEntryFile": {
      "type": "object",
      "required": ["catalogId", "catalogDisplay", "version", "entries"],
      "additionalProperties": false,
      "properties": {
        "catalogId": { "$ref": "#/$defs/CatalogId" },
        "catalogDisplay": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1, "description": "Date-based catalog version, e.g. '2026.06.18'." },
        "entries": { "type": "array", "items": { "$ref": "#/$defs/CatalogEntry" } }
      }
    }
  }
}
