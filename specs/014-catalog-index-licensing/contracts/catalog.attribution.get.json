{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/catalog.attribution.get.json",
  "title": "catalog.attribution.get",
  "description": "Read contract returning the per-catalog license attribution surface used by Settings → Catalogs. Separated from catalog.list so the (potentially large) notice text is not paid for on the metadata listing.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "1.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "CatalogId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "LicenseShortCode": {
      "type": "string",
      "enum": ["public-domain", "apache-2.0", "mit", "cc0-1.0", "cc-by-4.0", "cc-by-sa-4.0", "hyperleda", "esa-free"],
      "description": "Closed enum (R-2.1). CI hard-fails on unknown values."
    },
    "LicenseAttribution": {
      "type": "object",
      "required": ["catalog_id", "license", "text", "link"],
      "additionalProperties": false,
      "properties": {
        "catalog_id": { "$ref": "#/$defs/CatalogId" },
        "license": { "$ref": "#/$defs/LicenseShortCode" },
        "text": {
          "type": "string",
          "minLength": 1,
          "description": "Full required notice text, verbatim. Public-domain catalogs still carry a 'verified: <source>, accessed <date>' string."
        },
        "link": { "type": "string", "format": "uri" },
        "accessed_on": { "$ref": "#/$defs/Timestamp" },
        "author": {
          "type": "string",
          "description": "REQUIRED for cc-by-4.0 and cc-by-sa-4.0 licenses. Author or rights-holder name. (R-2.2)"
        },
        "title": {
          "type": "string",
          "description": "REQUIRED for cc-by-4.0 and cc-by-sa-4.0 licenses. Work title. (R-2.2)"
        },
        "license_uri": {
          "type": "string",
          "format": "uri",
          "description": "REQUIRED for cc-by-4.0 and cc-by-sa-4.0 licenses. Canonical license URL. (R-2.2)"
        },
        "modifications_notice": {
          "type": "string",
          "description": "Required if the project has modified the upstream data. Describes the nature of modifications. (R-2.2)"
        }
      },
      "if": {
        "properties": {
          "license": { "enum": ["cc-by-4.0", "cc-by-sa-4.0"] }
        },
        "required": ["license"]
      },
      "then": {
        "required": ["author", "title", "license_uri"]
      }
    },
    "ErrorCode": {
      "type": "string",
      "enum": ["registry.unavailable", "actor.not_authorised"]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "attributions": {
          "type": "array",
          "description": "Per-catalog attribution rows. One catalog may produce multiple rows when its bundle aggregates more than one upstream source.",
          "items": { "$ref": "#/$defs/LicenseAttribution" }
        },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["attributions"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
