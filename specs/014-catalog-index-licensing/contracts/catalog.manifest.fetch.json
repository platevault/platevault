{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/catalog.manifest.fetch.json",
  "title": "catalog.manifest.fetch",
  "description": "Fetch the current catalog manifest from the project-hosted manifests repository (astro-plan-catalogs, name TBD). Uses ETag-conditional HTTP to avoid re-downloading an unchanged manifest. Mirrors astro-up catalog/fetch.rs pattern. (R-1.2, R-1.4)",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "1.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "LicenseShortCode": {
      "type": "string",
      "enum": ["public-domain", "apache-2.0", "mit", "cc0-1.0", "cc-by-4.0", "cc-by-sa-4.0", "hyperleda", "esa-free"],
      "description": "Closed enum (R-2.1). CI hard-fails on unknown values."
    },
    "ManifestCatalogEntry": {
      "type": "object",
      "description": "Per-catalog entry in the signed manifest.",
      "required": ["catalog_id", "version", "url", "checksum", "license", "size_bytes"],
      "additionalProperties": false,
      "properties": {
        "catalog_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64,
          "pattern": "^[a-z0-9][a-z0-9_-]*$",
          "description": "Stable slug identifier, e.g. 'messier', 'opengc', 'lbn'."
        },
        "version": {
          "type": "string",
          "minLength": 1,
          "description": "Semver-ish version string for this catalog artifact."
        },
        "url": {
          "type": "string",
          "format": "uri",
          "description": "GitHub Releases download URL for the catalog artifact."
        },
        "checksum": {
          "type": "string",
          "description": "SHA-256 hex checksum of the catalog artifact bytes."
        },
        "license": { "$ref": "#/$defs/LicenseShortCode" },
        "size_bytes": {
          "type": "integer",
          "minimum": 1,
          "description": "Uncompressed size in bytes. Used for progress estimation."
        }
      }
    },
    "Manifest": {
      "type": "object",
      "description": "The signed catalog manifest. Present when status = 'fetched'.",
      "required": ["version", "signature", "catalogs"],
      "additionalProperties": false,
      "properties": {
        "version": {
          "type": "string",
          "description": "Semver manifest schema version, e.g. '1.0.0'."
        },
        "signature": {
          "type": "string",
          "description": "Minisign signature of the manifest content, base64-encoded. Verified in memory against the embedded public key before use. (R-1.2)"
        },
        "catalogs": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/ManifestCatalogEntry" }
        }
      }
    },
    "FetchStatus": {
      "type": "string",
      "enum": ["fetched", "not_modified", "failed"],
      "description": "'fetched': new manifest downloaded and verified. 'not_modified': ETag matched, local manifest is current (304). 'failed': network or verification error."
    },
    "ErrorCode": {
      "type": "string",
      "enum": [
        "manifest.fetch_failed",
        "manifest.signature_invalid",
        "manifest.checksum_mismatch",
        "network.unavailable",
        "actor.not_authorised"
      ]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "etag": {
          "type": "string",
          "description": "Optional If-None-Match value from a prior successful fetch. When present, sent as the HTTP If-None-Match header; a 304 response returns status 'not_modified'."
        }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "$ref": "#/$defs/FetchStatus" },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "manifest": { "$ref": "#/$defs/Manifest" },
        "etag": {
          "type": "string",
          "description": "ETag value returned by the server. Store and pass on the next request to enable conditional fetch."
        },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "fetched" } } },
          "then": {
            "required": ["manifest"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "not_modified" } } },
          "then": {
            "not": { "required": ["manifest"] },
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "failed" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
