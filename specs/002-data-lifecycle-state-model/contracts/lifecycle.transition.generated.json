  "definitions": {
    "DataSourceState": {
      "type": "string",
      "enum": [
        "active",
        "missing",
        "disabled",
        "reconnect_required"
      ]
    },
    "FileRecordState": {
      "type": "string",
      "enum": [
        "observed",
        "missing",
        "changed",
        "classified",
        "rejected",
        "protected"
      ]
    },
    "PlanState": {
      "description": "Ten-state plan lifecycle (spec 017 data-model.md `PlanState`). `paused` is surfaced here so the list/detail contracts can filter on it (R-Pause-1).",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "draft",
            "ready_for_review",
            "approved",
            "applying",
            "applied",
            "partially_applied",
            "failed",
            "cancelled",
            "discarded"
          ]
        },
        {
          "description": "Mid-apply suspension (R-Pause-1). Written only by spec 025's executor.",
          "type": "string",
          "enum": [
            "paused"
          ]
        }
      ]
    },
    "PreparedSourceState": {
      "type": "string",
      "enum": [
        "not_created",
        "planned",
        "ready",
        "stale",
        "retired"
      ]
    },
    "ProjectState": {
      "type": "string",
      "enum": [
        "setup_incomplete",
        "ready",
        "prepared",
        "processing",
        "completed",
        "archived",
        "blocked"
      ]
    },
    "ProjectionState": {
      "type": "string",
      "enum": [
        "current",
        "stale",
        "regenerating"
      ]
    },
    "SessionState": {
      "type": "string",
      "enum": [
        "discovered",
        "candidate",
        "needs_review",
        "confirmed",
        "rejected",
        "ignored"
      ]
    },
    "TransitionActor": {
      "type": "string",
      "enum": [
        "user",
        "system"
      ]
    }
  }
