{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TransitionRequest",
  "description": "Discriminated request — one variant per entity family.",
  "oneOf": [
    {
      "type": "object",
      "properties": {
        "entityType": {
          "type": "string",
          "const": "project"
        }
      },
      "$ref": "#/$defs/ProjectTransitionRequest",
      "required": [
        "entityType"
      ]
    },
    {
      "type": "object",
      "properties": {
        "entityType": {
          "type": "string",
          "const": "plan"
        }
      },
      "$ref": "#/$defs/PlanTransitionRequest",
      "required": [
        "entityType"
      ]
    },
    {
      "type": "object",
      "properties": {
        "entityType": {
          "type": "string",
          "const": "data_source"
        }
      },
      "$ref": "#/$defs/DataSourceTransitionRequest",
      "required": [
        "entityType"
      ]
    },
    {
      "type": "object",
      "properties": {
        "entityType": {
          "type": "string",
          "const": "prepared_source"
        }
      },
      "$ref": "#/$defs/PreparedSourceTransitionRequest",
      "required": [
        "entityType"
      ]
    },
    {
      "type": "object",
      "properties": {
        "entityType": {
          "type": "string",
          "const": "projection"
        }
      },
      "$ref": "#/$defs/ProjectionTransitionRequest",
      "required": [
        "entityType"
      ]
    },
    {
      "type": "object",
      "properties": {
        "entityType": {
          "type": "string",
          "const": "file_record"
        }
      },
      "$ref": "#/$defs/FileRecordTransitionRequest",
      "required": [
        "entityType"
      ]
    }
  ],
  "$defs": {
    "DataSourceState": {
      "type": "string",
      "enum": [
        "active",
        "missing",
        "disabled",
        "reconnect_required"
      ]
    },
    "DataSourceTransitionRequest": {
      "type": "object",
      "properties": {
        "actionLabel": {
          "type": [
            "string",
            "null"
          ]
        },
        "actor": {
          "$ref": "#/$defs/TransitionActor"
        },
        "contractVersion": {
          "type": "string"
        },
        "currentState": {
          "$ref": "#/$defs/DataSourceState"
        },
        "entityId": {
          "type": "string",
          "format": "uuid"
        },
        "nextState": {
          "$ref": "#/$defs/DataSourceState"
        },
        "requestId": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "contractVersion",
        "requestId",
        "entityId",
        "currentState",
        "nextState",
        "actor"
      ]
    },
    "FileRecordState": {
      "type": "string",
      "enum": [
        "observed",
        "missing",
        "changed",
        "classified",
        "rejected",
        "protected"
      ]
    },
    "FileRecordTransitionRequest": {
      "type": "object",
      "properties": {
        "actionLabel": {
          "type": [
            "string",
            "null"
          ]
        },
        "actor": {
          "$ref": "#/$defs/TransitionActor"
        },
        "contractVersion": {
          "type": "string"
        },
        "currentState": {
          "$ref": "#/$defs/FileRecordState"
        },
        "entityId": {
          "type": "string",
          "format": "uuid"
        },
        "nextState": {
          "$ref": "#/$defs/FileRecordState"
        },
        "requestId": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "contractVersion",
        "requestId",
        "entityId",
        "currentState",
        "nextState",
        "actor"
      ]
    },
    "PlanState": {
      "description": "Lifecycle state for a `FilesystemPlan`.\n\n10 variants per spec 002 data-model.md §FilesystemPlan (inc. `paused` R-Pause-1\nand `discarded` spec 017 retry-chain terminal).",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "draft",
            "ready_for_review",
            "approved",
            "applying",
            "applied",
            "partially_applied",
            "failed",
            "cancelled"
          ]
        },
        {
          "description": "Mid-apply suspension on `volume.unavailable`, `disk.full`, or `item.stale` (R-Pause-1).",
          "type": "string",
          "const": "paused"
        },
        {
          "description": "Soft-delete terminal — paired with spec 017 retry-chain semantics.",
          "type": "string",
          "const": "discarded"
        }
      ]
    },
    "PlanTransitionRequest": {
      "type": "object",
      "properties": {
        "actionLabel": {
          "type": [
            "string",
            "null"
          ]
        },
        "actor": {
          "$ref": "#/$defs/TransitionActor"
        },
        "contractVersion": {
          "type": "string"
        },
        "currentState": {
          "$ref": "#/$defs/PlanState"
        },
        "entityId": {
          "type": "string",
          "format": "uuid"
        },
        "nextState": {
          "$ref": "#/$defs/PlanState"
        },
        "requestId": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "contractVersion",
        "requestId",
        "entityId",
        "currentState",
        "nextState",
        "actor"
      ]
    },
    "PreparedSourceState": {
      "type": "string",
      "enum": [
        "not_created",
        "planned",
        "ready",
        "stale",
        "retired"
      ]
    },
    "PreparedSourceTransitionRequest": {
      "type": "object",
      "properties": {
        "actionLabel": {
          "type": [
            "string",
            "null"
          ]
        },
        "actor": {
          "$ref": "#/$defs/TransitionActor"
        },
        "contractVersion": {
          "type": "string"
        },
        "currentState": {
          "$ref": "#/$defs/PreparedSourceState"
        },
        "entityId": {
          "type": "string",
          "format": "uuid"
        },
        "nextState": {
          "$ref": "#/$defs/PreparedSourceState"
        },
        "requestId": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "contractVersion",
        "requestId",
        "entityId",
        "currentState",
        "nextState",
        "actor"
      ]
    },
    "ProjectState": {
      "description": "Lifecycle state for a `Project`.\n\n7 variants from spec 002 §Project and research.md §2.1.",
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "setup_incomplete",
            "ready",
            "prepared",
            "processing",
            "completed",
            "archived"
          ]
        },
        {
          "description": "Carries a `block_reason` on the entity row.",
          "type": "string",
          "const": "blocked"
        }
      ]
    },
    "ProjectTransitionRequest": {
      "type": "object",
      "properties": {
        "actionLabel": {
          "type": [
            "string",
            "null"
          ]
        },
        "actor": {
          "$ref": "#/$defs/TransitionActor"
        },
        "contractVersion": {
          "type": "string"
        },
        "currentState": {
          "$ref": "#/$defs/ProjectState"
        },
        "entityId": {
          "type": "string",
          "format": "uuid"
        },
        "nextState": {
          "$ref": "#/$defs/ProjectState"
        },
        "requestId": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "contractVersion",
        "requestId",
        "entityId",
        "currentState",
        "nextState",
        "actor"
      ]
    },
    "ProjectionState": {
      "type": "string",
      "enum": [
        "current",
        "stale",
        "regenerating"
      ]
    },
    "ProjectionTransitionRequest": {
      "type": "object",
      "properties": {
        "actionLabel": {
          "type": [
            "string",
            "null"
          ]
        },
        "actor": {
          "$ref": "#/$defs/TransitionActor"
        },
        "contractVersion": {
          "type": "string"
        },
        "currentState": {
          "$ref": "#/$defs/ProjectionState"
        },
        "entityId": {
          "type": "string",
          "format": "uuid"
        },
        "nextState": {
          "$ref": "#/$defs/ProjectionState"
        },
        "requestId": {
          "type": "string",
          "format": "uuid"
        }
      },
      "required": [
        "contractVersion",
        "requestId",
        "entityId",
        "currentState",
        "nextState",
        "actor"
      ]
    },
    "TransitionActor": {
      "type": "string",
      "enum": [
        "user",
        "system"
      ]
    }
  }
}
