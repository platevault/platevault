{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/lifecycle.transition.json",
  "title": "lifecycle.transition",
  "description": "Operation contract for proposing and applying a lifecycle state transition on a Data Asset. Source-of-truth schema for the Rust contract DTOs in crates/contracts/core/ and the generated TypeScript surface in packages/contracts/generated/.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": {
      "type": "string",
      "const": "1.0"
    },
    "Uuid": {
      "type": "string",
      "format": "uuid"
    },
    "Timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "Actor": {
      "type": "string",
      "description": "Initiator of the transition. `actor=system` is only permitted on edges entering or leaving `blocked` (per spec 009 ratification). Use-case layer enforces the rule and rejects violations with `transition.refused`.",
      "enum": ["user", "system"]
    },
    "EntityType": {
      "type": "string",
      "enum": [
        "library_root",
        "file_record",
        "acquisition_session",
        "calibration_session",
        "data_source",
        "project",
        "prepared_source",
        "processing_artifact",
        "projection",
        "plan",
        "inventory_session",
        "filesystem_plan"
      ]
    },
    "ProjectState": {
      "type": "string",
      "enum": [
        "setup_incomplete",
        "ready",
        "prepared",
        "processing",
        "completed",
        "archived",
        "blocked"
      ]
    },
    "PlanState": {
      "type": "string",
      "enum": [
        "draft",
        "ready_for_review",
        "approved",
        "applying",
        "applied",
        "partially_applied",
        "failed",
        "cancelled",
        "discarded"
      ]
    },
    "SessionState": {
      "type": "string",
      "enum": [
        "discovered",
        "candidate",
        "needs_review",
        "confirmed",
        "rejected",
        "ignored"
      ]
    },
    "DataSourceState": {
      "type": "string",
      "enum": ["active", "missing", "disabled", "reconnect_required"]
    },
    "FileRecordState": {
      "type": "string",
      "enum": [
        "observed",
        "missing",
        "changed",
        "classified",
        "rejected",
        "protected"
      ]
    },
    "PreparedSourceState": {
      "type": "string",
      "enum": ["not_created", "planned", "ready", "stale", "retired"]
    },
    "ProjectionState": {
      "type": "string",
      "enum": ["current", "stale", "regenerating"]
    },
    "ProjectRequest": {
      "type": "object",
      "required": [
        "contractVersion",
        "requestId",
        "entity_type",
        "entity_id",
        "current_state",
        "next_state",
        "actor"
      ],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "entity_type": { "type": "string", "const": "project" },
        "entity_id": { "$ref": "#/$defs/Uuid" },
        "current_state": { "$ref": "#/$defs/ProjectState" },
        "next_state": { "$ref": "#/$defs/ProjectState" },
        "action_label": { "$ref": "#/$defs/ActionLabel" },
        "actor": { "$ref": "#/$defs/Actor" }
      }
    },
    "PlanRequest": {
      "type": "object",
      "required": [
        "contractVersion",
        "requestId",
        "entity_type",
        "entity_id",
        "current_state",
        "next_state",
        "actor"
      ],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "entity_type": { "type": "string", "const": "plan" },
        "entity_id": { "$ref": "#/$defs/Uuid" },
        "current_state": { "$ref": "#/$defs/PlanState" },
        "next_state": { "$ref": "#/$defs/PlanState" },
        "action_label": { "$ref": "#/$defs/ActionLabel" },
        "actor": { "$ref": "#/$defs/Actor" }
      }
    },
    "InventorySessionRequest": {
      "type": "object",
      "required": [
        "contractVersion",
        "requestId",
        "entity_type",
        "entity_id",
        "current_state",
        "next_state",
        "actor"
      ],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "entity_type": { "type": "string", "const": "inventory_session" },
        "entity_id": { "$ref": "#/$defs/Uuid" },
        "current_state": { "$ref": "#/$defs/SessionState" },
        "next_state": { "$ref": "#/$defs/SessionState" },
        "action_label": { "$ref": "#/$defs/ActionLabel" },
        "actor": { "$ref": "#/$defs/Actor" }
      }
    },
    "CalibrationSessionRequest": {
      "type": "object",
      "required": [
        "contractVersion",
        "requestId",
        "entity_type",
        "entity_id",
        "current_state",
        "next_state",
        "actor"
      ],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "entity_type": { "type": "string", "const": "calibration_session" },
        "entity_id": { "$ref": "#/$defs/Uuid" },
        "current_state": { "$ref": "#/$defs/SessionState" },
        "next_state": { "$ref": "#/$defs/SessionState" },
        "action_label": { "$ref": "#/$defs/ActionLabel" },
        "actor": { "$ref": "#/$defs/Actor" }
      }
    },
    "DataSourceRequest": {
      "type": "object",
      "required": [
        "contractVersion",
        "requestId",
        "entity_type",
        "entity_id",
        "current_state",
        "next_state",
        "actor"
      ],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "entity_type": { "type": "string", "const": "data_source" },
        "entity_id": { "$ref": "#/$defs/Uuid" },
        "current_state": { "$ref": "#/$defs/DataSourceState" },
        "next_state": { "$ref": "#/$defs/DataSourceState" },
        "action_label": { "$ref": "#/$defs/ActionLabel" },
        "actor": { "$ref": "#/$defs/Actor" }
      }
    },
    "PreparedSourceRequest": {
      "type": "object",
      "required": [
        "contractVersion",
        "requestId",
        "entity_type",
        "entity_id",
        "current_state",
        "next_state",
        "actor"
      ],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "entity_type": { "type": "string", "const": "prepared_source" },
        "entity_id": { "$ref": "#/$defs/Uuid" },
        "current_state": { "$ref": "#/$defs/PreparedSourceState" },
        "next_state": { "$ref": "#/$defs/PreparedSourceState" },
        "action_label": { "$ref": "#/$defs/ActionLabel" },
        "actor": { "$ref": "#/$defs/Actor" }
      }
    },
    "ProjectionRequest": {
      "type": "object",
      "required": [
        "contractVersion",
        "requestId",
        "entity_type",
        "entity_id",
        "current_state",
        "next_state",
        "actor"
      ],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "entity_type": { "type": "string", "const": "projection" },
        "entity_id": { "$ref": "#/$defs/Uuid" },
        "current_state": { "$ref": "#/$defs/ProjectionState" },
        "next_state": { "$ref": "#/$defs/ProjectionState" },
        "action_label": { "$ref": "#/$defs/ActionLabel" },
        "actor": { "$ref": "#/$defs/Actor" }
      }
    },
    "FileRecordRequest": {
      "type": "object",
      "required": [
        "contractVersion",
        "requestId",
        "entity_type",
        "entity_id",
        "current_state",
        "next_state",
        "actor"
      ],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "entity_type": { "type": "string", "const": "file_record" },
        "entity_id": { "$ref": "#/$defs/Uuid" },
        "current_state": { "$ref": "#/$defs/FileRecordState" },
        "next_state": { "$ref": "#/$defs/FileRecordState" },
        "action_label": { "$ref": "#/$defs/ActionLabel" },
        "actor": { "$ref": "#/$defs/Actor" }
      }
    },
    "ActionLabel": {
      "type": "string",
      "description": "Human-readable label recorded on the audit entry (e.g. 'Unarchived').",
      "minLength": 1,
      "maxLength": 120
    },
    "LifecycleState": {
      "description": "Any per-family lifecycle state value. Use the family-specific enums in the discriminated Request sub-schemas; this alias exists only for the Response shape where the family is fixed by the corresponding request.",
      "oneOf": [
        { "$ref": "#/$defs/ProjectState" },
        { "$ref": "#/$defs/PlanState" },
        { "$ref": "#/$defs/SessionState" },
        { "$ref": "#/$defs/DataSourceState" },
        { "$ref": "#/$defs/FileRecordState" },
        { "$ref": "#/$defs/PreparedSourceState" },
        { "$ref": "#/$defs/ProjectionState" }
      ]
    },
    "ErrorCode": {
      "type": "string",
      "enum": [
        "transition.refused",
        "entity.not_found",
        "actor.not_authorised",
        "plan.required",
        "plan.not_approved",
        "provenance.unreviewed"
      ]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": {
          "type": "string",
          "description": "Human-readable explanation. MUST NOT include secrets or absolute filesystem paths."
        },
        "details": {
          "type": "object",
          "description": "Optional structured detail. Examples: { allowed_next_states: [...] } for transition.refused; { plan_id: uuid } for plan.required; { blocking_fields: [{ field_path, required_origin: 'reviewed' }] } for provenance.unreviewed.",
          "additionalProperties": true,
          "properties": {
            "allowed_next_states": {
              "type": "array",
              "items": { "type": "string" }
            },
            "plan_id": { "$ref": "#/$defs/Uuid" },
            "blocking_fields": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["field_path", "required_origin"],
                "additionalProperties": false,
                "properties": {
                  "field_path": { "type": "string" },
                  "required_origin": {
                    "type": "string",
                    "enum": ["reviewed"]
                  }
                }
              }
            }
          }
        }
      }
    },
    "Request": {
      "description": "Discriminated request envelope. Each branch pins `entity_type` to a single family and constrains `current_state`/`next_state` to that family's enum. The server derives `requires_plan` from a canonical (entity_type, from, to) edge table; callers MUST NOT assert it.",
      "oneOf": [
        { "$ref": "#/$defs/ProjectRequest" },
        { "$ref": "#/$defs/PlanRequest" },
        { "$ref": "#/$defs/InventorySessionRequest" },
        { "$ref": "#/$defs/CalibrationSessionRequest" },
        { "$ref": "#/$defs/DataSourceRequest" },
        { "$ref": "#/$defs/PreparedSourceRequest" },
        { "$ref": "#/$defs/ProjectionRequest" },
        { "$ref": "#/$defs/FileRecordRequest" }
      ]
    },
    "Response": {
      "type": "object",
      "description": "Response envelope for lifecycle.transition.",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "noop", "error"],
          "description": "`success` = state mutated and audit row written. `noop` = caller-requested next_state equals current_state; no mutation, no audit row, no error. `error` = transition refused or otherwise rejected; structured `error` field populated."
        },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "applied_at": { "$ref": "#/$defs/Timestamp" },
        "prior_state": { "$ref": "#/$defs/LifecycleState" },
        "new_state": { "$ref": "#/$defs/LifecycleState" },
        "audit_id": { "$ref": "#/$defs/Uuid" },
        "plan_id": {
          "$ref": "#/$defs/Uuid",
          "description": "Set when the server created or referenced a FilesystemPlan whose approval gates the transition."
        },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["applied_at", "new_state", "audit_id"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "noop" } } },
          "then": {
            "not": {
              "anyOf": [
                { "required": ["audit_id"] },
                { "required": ["error"] }
              ]
            }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
