{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/tool.launch.json",
  "title": "tool.launch",
  "description": "Launch a configured processing tool for a given project. Returns a launchId that spec 012 (Processing Artifact Observation) can correlate with emitted artifacts. Launch never mutates project lifecycle state.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "2.0.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "ToolId": {
      "type": "string",
      "description": "Stable tool identifier matching ToolProfile.id.",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "ErrorCode": {
      "type": "string",
      "description": "Launch-scoped error codes layered on the shared ErrorEnvelope.",
      "enum": [
        "tool.not_configured",
        "tool.executable.not_found",
        "project.not_found",
        "launch.failed",
        "cwd.outside_library_root",
        "macos.quarantine.detected"
      ]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": {
          "type": "string",
          "description": "Human-readable explanation. MUST NOT include secrets or absolute filesystem paths."
        },
        "details": {
          "type": "object",
          "description": "Structured context. tool.not_configured MUST include toolId. tool.executable.not_found MUST include toolId and a sanitised reason. launch.failed MUST include osErrorKind.",
          "additionalProperties": true,
          "properties": {
            "toolId": { "$ref": "#/$defs/ToolId" },
            "reason": { "type": "string", "maxLength": 240 },
            "osErrorKind": { "type": "string", "maxLength": 64 }
          }
        }
      }
    },
    "Request": {
      "type": "object",
      "description": "Launch the configured tool for the given project.",
      "required": [
        "contractVersion",
        "requestId",
        "projectId",
        "toolId"
      ],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "projectId": { "$ref": "#/$defs/Uuid" },
        "toolId": { "$ref": "#/$defs/ToolId" },
        "force": {
          "type": "boolean",
          "default": false,
          "description": "When true, suppress the 'tool already running' warning and spawn a new instance regardless of any live prior PID for this (project, tool)."
        }
      }
    },
    "Response": {
      "type": "object",
      "description": "Launch outcome. status=success implies the OS reported the child as spawned; the tool may still fail to display a window for tool-specific reasons (out of scope for this contract).",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "launchId": { "$ref": "#/$defs/Uuid" },
        "pid": {
          "type": ["integer", "null"],
          "minimum": 0,
          "description": "OS-reported process id. Null on platforms where the immediate PID is not surfaced before detach — most notably macOS when using 'open -b <bundle_id>'."
        },
        "launchedAt": { "$ref": "#/$defs/Timestamp" },
        "workingDir": {
          "type": "string",
          "description": "The cwd that was passed to the child. Surface this in audit/UI; never echo secrets."
        },
        "auditId": { "$ref": "#/$defs/Uuid" },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["launchId", "launchedAt", "workingDir", "auditId"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
