{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plan.protection.check",
  "title": "Check plan protection",
  "description": "Returns protection-affected items for a plan so the review UI can gate execution.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "required": ["plan_id"],
      "properties": {
        "plan_id": { "type": "string", "format": "uuid" }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": ["has_protected_items", "protected_items", "non_blocking_summary"],
      "description": "Response includes ONLY items requiring user acknowledgement (level = protected or items rewritten by block_permanent_delete). Normal and unprotected items are summarised in non_blocking_summary (R-CheckScope).",
      "properties": {
        "has_protected_items": { "type": "boolean" },
        "protected_items": {
          "type": "array",
          "description": "Items that require explicit user acknowledgement before the plan may execute. Excludes normal and unprotected items.",
          "items": {
            "type": "object",
            "required": ["item_id", "level", "reason", "requires_acknowledgement"],
            "properties": {
              "item_id": { "type": "string", "format": "uuid" },
              "source_id": { "type": "string", "format": "uuid" },
              "level": {
                "type": "string",
                "enum": ["protected", "normal", "unprotected"]
              },
              "matched_categories": {
                "type": "array",
                "items": { "type": "string" }
              },
              "original_action": { "type": "string" },
              "rewritten_action": {
                "type": ["string", "null"],
                "description": "Set when block_permanent_delete rewrote the action (e.g., delete -> archive)."
              },
              "requires_acknowledgement": { "type": "boolean" },
              "reason": { "type": "string" }
            },
            "additionalProperties": false
          }
        },
        "non_blocking_summary": {
          "type": "object",
          "description": "Counts of items that do NOT require acknowledgement (R-CheckScope).",
          "required": ["normal_count", "unprotected_count"],
          "properties": {
            "normal_count": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of plan items whose resolved level is 'normal'."
            },
            "unprotected_count": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of plan items whose resolved level is 'unprotected'."
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "enum": ["plan.not_found"] },
          "message": { "type": "string" }
        }
      }
    }
  },
  "required": ["request", "response"]
}
