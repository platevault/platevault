{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/plan.protection.check.json",
  "title": "plan.protection.check",
  "description": "Returns protection-affected items for a plan so the review UI can gate execution.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "2.0.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "ProtectionLevel": {
      "type": "string",
      "enum": ["protected", "normal", "unprotected"]
    },
    "ProtectedItem": {
      "type": "object",
      "required": ["itemId", "level", "reason", "requiresAcknowledgement"],
      "additionalProperties": false,
      "properties": {
        "itemId": { "$ref": "#/$defs/Uuid" },
        "sourceId": { "$ref": "#/$defs/Uuid" },
        "level": { "$ref": "#/$defs/ProtectionLevel" },
        "matchedCategories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "originalAction": { "type": "string" },
        "rewrittenAction": {
          "type": ["string", "null"],
          "description": "Set when block_permanent_delete rewrote the action (e.g., delete -> archive)."
        },
        "requiresAcknowledgement": { "type": "boolean" },
        "reason": { "type": "string" }
      }
    },
    "NonBlockingSummary": {
      "type": "object",
      "description": "Counts of items that do NOT require acknowledgement (R-CheckScope).",
      "required": ["normalCount", "unprotectedCount"],
      "additionalProperties": false,
      "properties": {
        "normalCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of plan items whose resolved level is 'normal'."
        },
        "unprotectedCount": {
          "type": "integer",
          "minimum": 0,
          "description": "Number of plan items whose resolved level is 'unprotected'."
        }
      }
    },
    "ErrorCode": {
      "type": "string",
      "enum": ["plan.not_found"]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "planId"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "planId": { "$ref": "#/$defs/Uuid" }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "hasProtectedItems": { "type": "boolean" },
        "protectedItems": {
          "type": "array",
          "description": "Items that require explicit user acknowledgement before the plan may execute. Excludes normal and unprotected items.",
          "items": { "$ref": "#/$defs/ProtectedItem" }
        },
        "nonBlockingSummary": { "$ref": "#/$defs/NonBlockingSummary" },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["hasProtectedItems", "protectedItems", "nonBlockingSummary"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
