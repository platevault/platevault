{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/source.protection.set.json",
  "title": "source.protection.set",
  "description": "Sets or replaces the protection override for a source.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "2.0.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "ProtectionLevel": {
      "type": "string",
      "enum": ["protected", "normal", "unprotected"]
    },
    "ErrorCode": {
      "type": "string",
      "enum": ["source.not_found", "level.unknown"]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "sourceId", "level"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "sourceId": { "$ref": "#/$defs/Uuid" },
        "level": { "$ref": "#/$defs/ProtectionLevel" },
        "blockPermanentDelete": {
          "type": ["boolean", "null"],
          "description": "Per-source override for blockPermanentDelete. null = inherit global value; true/false = explicit override (A2). Absent is treated as null (inherit)."
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Optional per-source category override. Absent means inherit global protected categories."
        }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "sourceId": { "$ref": "#/$defs/Uuid" },
        "priorLevel": { "$ref": "#/$defs/ProtectionLevel" },
        "newLevel": { "$ref": "#/$defs/ProtectionLevel" },
        "priorBlockPermanentDelete": {
          "type": ["boolean", "null"],
          "description": "Prior per-source override value. null means was inheriting global."
        },
        "newBlockPermanentDelete": {
          "type": ["boolean", "null"],
          "description": "New per-source override value. null means now inheriting global."
        },
        "priorCategories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "newCategories": {
          "type": "array",
          "items": { "type": "string" }
        },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["sourceId", "priorLevel", "newLevel"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
