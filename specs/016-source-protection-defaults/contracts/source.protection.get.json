{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/source.protection.get.json",
  "title": "source.protection.get",
  "description": "Resolves effective protection for a source, or returns global defaults when sourceId is omitted.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "2.0.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "ProtectionLevel": {
      "type": "string",
      "enum": ["protected", "normal", "unprotected"]
    },
    "ErrorCode": {
      "type": "string",
      "enum": ["source.not_found"]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "sourceId": {
          "$ref": "#/$defs/Uuid",
          "description": "Source to inspect. Omit for global defaults."
        }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "sourceId": {
          "$ref": "#/$defs/Uuid",
          "description": "Echo of the requested sourceId. Absent when global defaults are returned."
        },
        "level": {
          "$ref": "#/$defs/ProtectionLevel",
          "description": "Effective protection level (resolved: per-source override wins unconditionally; categories elevate only when no override row exists)."
        },
        "blockPermanentDelete": {
          "type": "boolean",
          "description": "Effective blockPermanentDelete. Resolved from per-source override when present and non-null; otherwise from global default (A2)."
        },
        "categories": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Protected categories applicable to this source."
        },
        "inheritsDefault": {
          "type": "boolean",
          "description": "True when no per-source override exists and global defaults were returned."
        },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["level", "blockPermanentDelete", "categories"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
