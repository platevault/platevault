{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan/contracts/theme.get.json",
  "title": "theme.get",
  "description": "Read the current desktop theme mode and the resolved (effective) theme. 'mode' is the user's chosen setting and may be 'system', 'light', or 'dark'. 'resolved' is the concrete theme in effect after resolving 'system' against the OS preference, and is always 'light' or 'dark'.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "mode", "resolved"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "mode": {
              "type": "string",
              "enum": ["system", "light", "dark"],
              "description": "User-chosen theme mode. 'system' means follow the OS appearance setting."
            },
            "resolved": {
              "type": "string",
              "enum": ["light", "dark"],
              "description": "Effective theme after resolving 'system' against the OS preference."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
