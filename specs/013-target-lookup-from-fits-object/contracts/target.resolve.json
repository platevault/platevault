{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/target.resolve.json",
  "title": "target.resolve",
  "description": "Operation contract for resolving a single FITS OBJECT header value to a stable Target identity. Wraps target.lookup with single-result semantics suitable for ingestion. Source-of-truth schema for the Rust contract DTOs in crates/contracts/core/ and the generated TypeScript surface in packages/contracts/generated/.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" },
    { "$ref": "#/$defs/Error" }
  ],
  "$defs": {
    "ContractVersion": {
      "type": "string",
      "const": "1.0"
    },
    "Uuid": {
      "type": "string",
      "format": "uuid"
    },
    "Confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "Request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_version", "fits_object_value"],
      "properties": {
        "contract_version": { "$ref": "#/$defs/ContractVersion" },
        "fits_object_value": {
          "type": "string",
          "description": "Raw FITS OBJECT header value as extracted from the light frame."
        }
      }
    },
    "Response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_version", "target_id", "confidence"],
      "properties": {
        "contract_version": { "$ref": "#/$defs/ContractVersion" },
        "target_id": { "$ref": "#/$defs/Uuid" },
        "confidence": { "$ref": "#/$defs/Confidence" }
      }
    },
    "Error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contract_version", "error"],
      "properties": {
        "contract_version": { "$ref": "#/$defs/ContractVersion" },
        "error": {
          "type": "object",
          "additionalProperties": false,
          "required": ["code", "message"],
          "properties": {
            "code": {
              "type": "string",
              "enum": ["unresolved", "ambiguous"],
              "description": "unresolved: no candidate above the discard threshold. ambiguous: multiple candidates with overlapping confidence; caller should fall back to target.lookup to present a chooser."
            },
            "message": { "type": "string", "minLength": 1 },
            "candidates": {
              "type": "array",
              "description": "Optional: present when code is 'ambiguous'. Ranked candidate target_ids with confidence so the UI can route to a chooser without a second lookup.",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["target_id", "confidence"],
                "properties": {
                  "target_id": { "$ref": "#/$defs/Uuid" },
                  "confidence": { "$ref": "#/$defs/Confidence" }
                }
              }
            }
          }
        }
      }
    }
  }
}
