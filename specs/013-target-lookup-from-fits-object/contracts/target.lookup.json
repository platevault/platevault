{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/target.lookup.json",
  "title": "target.lookup",
  "description": "Operation contract for looking up candidate Targets from a free-form query string. Returns a ranked list of TargetMatch records for the UI catalog picker. The active catalog set is server-derived from spec 018 settings (target_lookup.active_catalogs); callers cannot override it per-request (R8). Source-of-truth schema for the Rust contract DTOs in crates/contracts/core/ and the generated TypeScript surface in packages/contracts/generated/.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": {
      "type": "string",
      "const": "1.0"
    },
    "Uuid": {
      "type": "string",
      "format": "uuid"
    },
    "Confidence": {
      "type": "string",
      "enum": ["high", "medium", "low"]
    },
    "Strategy": {
      "type": "string",
      "enum": ["exact", "token_set", "edit_distance"]
    },
    "CatalogId": {
      "type": "string",
      "enum": [
        "messier",
        "caldwell",
        "sharpless",
        "abell_pn",
        "abell_galaxies",
        "arp",
        "vdb",
        "barnard",
        "lbn",
        "ldn",
        "melotte",
        "common",
        "openngc"
      ],
      "description": "Closed enum of v1 catalog slugs. Ref: spec 014 catalog set."
    },
    "MatchEvidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["matched_alias", "normalized_query", "strategy", "score"],
      "properties": {
        "matched_alias": { "type": "string", "minLength": 1 },
        "normalized_query": { "type": "string" },
        "strategy": { "$ref": "#/$defs/Strategy" },
        "score": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "TargetMatch": {
      "type": "object",
      "additionalProperties": false,
      "required": ["target_id", "primary_designation", "catalog_display", "confidence", "score", "evidence"],
      "properties": {
        "target_id": { "$ref": "#/$defs/Uuid" },
        "primary_designation": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical display designation chosen by precedence table (R6)."
        },
        "catalog_display": {
          "type": "string",
          "minLength": 1,
          "description": "Human-readable name of the precedence-winning catalog (e.g. 'Messier')."
        },
        "confidence": { "$ref": "#/$defs/Confidence" },
        "score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "description": "Raw similarity score. 100 for exact matches."
        },
        "evidence": { "$ref": "#/$defs/MatchEvidence" }
      }
    },
    "Request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "query"],
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "query": {
          "type": "string",
          "description": "Free-form lookup query. Typically the raw FITS OBJECT value or a user-entered string."
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 50,
          "default": 10,
          "description": "Maximum number of matches to return, ranked by confidence then score."
        }
      }
    },
    "Response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "contractVersion", "requestId"],
      "properties": {
        "status": {
          "type": "string",
          "enum": ["success", "error"]
        },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "matches": {
          "type": "array",
          "items": { "$ref": "#/$defs/TargetMatch" },
          "description": "Ranked candidate matches. Present when status=success. Empty array indicates no candidates above the discard threshold."
        },
        "errors": {
          "type": "array",
          "description": "Present when status=error.",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message"],
            "properties": {
              "code": {
                "type": "string",
                "enum": [
                  "query.empty",
                  "catalog.unavailable",
                  "catalog.not_installed"
                ],
                "description": "query.empty: missing or whitespace-only query. catalog.unavailable: index failed to load from SQLite. catalog.not_installed: first-run download not yet completed (FR-005)."
              },
              "message": { "type": "string", "minLength": 1 }
            }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": { "required": ["matches"] }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["errors"] }
        }
      ]
    }
  }
}
