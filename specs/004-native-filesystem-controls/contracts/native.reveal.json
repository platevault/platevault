{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-library-manager.local/contracts/native.reveal.json",
  "title": "native.reveal",
  "description": "Open the OS file browser at the given path with the target selected when the host platform supports per-item selection. Implemented over tauri-plugin-opener revealItemInDir with documented per-platform fallbacks (macOS open -R, Windows explorer.exe /select,, Linux freedesktop ShowItems with xdg-open directory fallback).",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "path"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": {
          "type": "string",
          "format": "uuid"
        },
        "path": {
          "description": "Absolute path to reveal. May point to a file or directory. Existence is checked at dispatch time, not at input-validation time.",
          "type": "string",
          "minLength": 1
        },
        "entityKind": {
          "description": "Optional context tag for audit-log correlation.",
          "type": "string",
          "enum": [
            "inbox_item",
            "inventory_row",
            "project_manifest",
            "master_calibration",
            "registered_source",
            "other"
          ]
        },
        "entityId": {
          "type": "string"
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "revealed", "selection"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "revealed": {
              "description": "True when the OS file browser launched successfully.",
              "type": "boolean"
            },
            "selection": {
              "description": "How the target was highlighted. `target` means the item was selected (macOS, Windows, Linux with freedesktop ShowItems). `directory_only` means only the parent directory opened (Linux fallback). `none` means no UI hint was applied.",
              "type": "string",
              "enum": ["target", "directory_only", "none"]
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["path.not_exists", "os.command_failed"]
        },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
