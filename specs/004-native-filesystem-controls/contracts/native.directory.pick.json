{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-library-manager.local/contracts/native.directory.pick.json",
  "title": "native.directory.pick",
  "description": "Open the OS-native directory picker and return the user-selected absolute path. Cancellation is a non-error null response. Implemented over @tauri-apps/plugin-dialog with directory=true, multiple=false.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "required": ["contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": {
          "description": "Client-generated UUID for log correlation.",
          "type": "string",
          "format": "uuid"
        },
        "defaultPath": {
          "description": "Optional absolute path to anchor the dialog. Honored where the host OS supports it. Silently ignored when the path does not exist.",
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "path", "cancelled"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "path": {
              "description": "Absolute OS-canonical path the user selected, or null when the user cancelled the dialog.",
              "type": ["string", "null"]
            },
            "cancelled": {
              "description": "True when the user dismissed the dialog without selecting. Mirrors path === null.",
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["picker.unavailable", "os.command_failed"]
        },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
