{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-library-manager.local/contracts/native.file.pick.json",
  "title": "native.file.pick",
  "description": "Open the OS-native file picker with type filters and return the user-selected absolute path. Cancellation is a non-error null response. Implemented over @tauri-apps/plugin-dialog with directory=false, multiple=false. Used by master-calibration selection for FITS, XISF, and TIFF files.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "filters"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" },
        "filters": {
          "description": "Ordered list of file-type filters. The first filter is the default. Extensions MUST NOT include the leading dot.",
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "extensions"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "minLength": 1
              },
              "extensions": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "string",
                  "pattern": "^[A-Za-z0-9*]+$"
                },
                "description": "Extensions without leading dot. The wildcard '*' is ONLY valid in a filter named exactly 'All files'; the server returns filters.invalid if '*' appears in any other filter row (D-004-1)."
              }
            }
          }
        },
        "defaultPath": {
          "description": "Optional absolute path to anchor the dialog (typically the calibration source root). Honored where supported.",
          "type": ["string", "null"],
          "minLength": 1
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "path", "cancelled"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "path": {
              "description": "Absolute OS-canonical path the user selected, or null when the user cancelled.",
              "type": ["string", "null"]
            },
            "selectedFilter": {
              "description": "The name of the filter active when the user clicked Open. Useful for recording the user's declared frame type.",
              "type": ["string", "null"]
            },
            "cancelled": {
              "type": "boolean"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["picker.unavailable", "filters.invalid", "os.command_failed"]
        },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
