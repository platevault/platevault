{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/calibration.match.assign.json",
  "title": "calibration.match.assign",
  "description": "Persist a calibration master assignment for a light session. Hard-rule mismatches require override=true.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "2.0.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "CalibrationType": {
      "type": "string",
      "enum": ["dark", "flat", "bias"]
    },
    "Assigned": {
      "type": "object",
      "required": ["assignmentId", "sessionId", "masterId", "calibrationType", "wasOverride"],
      "additionalProperties": false,
      "properties": {
        "assignmentId": { "$ref": "#/$defs/Uuid" },
        "sessionId": { "$ref": "#/$defs/Uuid" },
        "masterId": { "$ref": "#/$defs/Uuid" },
        "calibrationType": { "$ref": "#/$defs/CalibrationType" },
        "wasOverride": { "type": "boolean" },
        "mismatchedDimensions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "assignedAt": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "ErrorCode": {
      "type": "string",
      "enum": [
        "master.not_found",
        "incompatible.dimensions",
        "session.not_found",
        "session.mixed_state",
        "match.observer_location_missing"
      ]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "dimensions": {
              "type": "array",
              "description": "On incompatible.dimensions, lists hard-rule dimensions that mismatched.",
              "items": { "type": "string" }
            }
          }
        }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "sessionId", "masterId", "override"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "sessionId": {
          "$ref": "#/$defs/Uuid",
          "description": "Light session being assigned."
        },
        "masterId": {
          "$ref": "#/$defs/Uuid",
          "description": "Calibration master to assign. Its calibrationType implicitly determines the target slot."
        },
        "override": {
          "type": "boolean",
          "description": "When true, accepts hard-rule mismatches and records them in audit history."
        }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "assigned": { "$ref": "#/$defs/Assigned" },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Confidence captured at assignment time using the active MatchingRuleConfig."
        },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["assigned", "confidence"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
