{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/calibration.match.suggest.json",
  "title": "calibration.match.suggest",
  "description": "Request ranked calibration master suggestions for a light session. Read-only; never persists state.",
  "version": "1.0.0",
  "type": "object",
  "properties": {
    "operation": { "const": "calibration.match.suggest" },
    "request": {
      "type": "object",
      "required": ["session_id"],
      "properties": {
        "session_id": {
          "type": "string",
          "format": "uuid",
          "description": "Light session whose calibration recommendations are being requested."
        },
        "calibration_types": {
          "type": "array",
          "description": "Subset of calibration types to suggest. When omitted, all configured types are returned.",
          "items": { "enum": ["dark", "flat", "bias"] },
          "uniqueItems": true
        }
      },
      "additionalProperties": false
    },
    "response": {
      "type": "object",
      "required": ["matches"],
      "properties": {
        "matches": {
          "type": "array",
          "description": "Ranked candidate list. Ordering is descending by confidence; ties broken by selection_reason precedence (same_session > same_night > compatible_fallback).",
          "items": { "$ref": "#/$defs/CalibrationMatch" }
        }
      },
      "additionalProperties": false
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": { "enum": ["session.not_found", "no.masters.available"] },
          "message": { "type": "string" }
        }
      }
    }
  },
  "required": ["operation", "request", "response"],
  "$defs": {
    "CalibrationMatch": {
      "type": "object",
      "required": [
        "session_id",
        "master_id",
        "calibration_type",
        "confidence",
        "dimensions_matched",
        "dimensions_mismatched",
        "selection_reason"
      ],
      "properties": {
        "session_id": { "type": "string", "format": "uuid" },
        "master_id": { "type": "string", "format": "uuid" },
        "calibration_type": { "enum": ["dark", "flat", "bias"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "dimensions_matched": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["dimension"],
            "properties": {
              "dimension": { "type": "string" },
              "observed": {},
              "reference": {},
              "delta": { "type": "number" }
            }
          }
        },
        "dimensions_mismatched": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["dimension", "reason"],
            "properties": {
              "dimension": { "type": "string" },
              "reason": { "enum": ["out_of_tolerance", "metadata_missing", "hard_rule_violation"] },
              "delta": { "type": "number" }
            }
          }
        },
        "selection_reason": {
          "enum": ["same_session", "same_night", "compatible_fallback"]
        }
      },
      "additionalProperties": false
    }
  }
}
