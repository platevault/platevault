{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan/contracts/settings.source-override.set.json",
  "title": "settings.source-override.set",
  "description": "Set a per-source override for an overridable settings key. To clear an override, omit 'value' or call the dedicated clear operation (out of scope here).",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "sourceId", "key", "value"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" },
        "sourceId": {
          "type": "string",
          "description": "Identifier of the data source root receiving the override."
        },
        "key": {
          "type": "string",
          "description": "One of the overridable settings keys.",
          "enum": [
            "followSymlinks",
            "hashOnScan",
            "defaultProtection"
          ]
        },
        "value": {
          "description": "Override value; must validate against the same per-key sub-schema as the global key."
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "sourceId", "key"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "sourceId": { "type": "string" },
            "key": { "type": "string" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["source.not_found", "key.unoverridable"]
        },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
