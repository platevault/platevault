{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan/contracts/settings.restore-defaults.json",
  "title": "settings.restore-defaults",
  "description": "Restore one, several, or all v1 settings keys to their in-code defaults by writing the literal default value as an explicit row (A3). Empty 'keys' restores all keys. Keys already at default return status='noop' with no row write and no audit event (R-3.1, cross-ref spec 002 noop pattern).",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" },
        "keys": {
          "type": "array",
          "description": "List of v1 settings keys to restore. Empty or omitted means restore every key.",
          "uniqueItems": true,
          "items": {
            "oneOf": [
              {
                "type": "string",
                "enum": [
                  "pattern",
                  "autoApplyPattern",
                  "alwaysPreviewBeforePlan",
                  "followSymlinks",
                  "hashOnScan",
                  "darkMatchTolerance",
                  "flatMatching",
                  "suggestCalibration",
                  "rowDensity",
                  "logLevel",
                  "rememberFollowLogs",
                  "defaultProtection",
                  "blockPermanentDelete",
                  "protectedCategories",
                  "currentLibraryId",
                  "devMode",
                  "target_lookup.active_catalogs",
                  "calibrationDarkTempTolerance",
                  "calibrationPrefillSuggestion",
                  "calibrationDarkOverridePenalty",
                  "calibrationFlatOverridePenalty",
                  "calibrationBiasOverridePenalty",
                  "calibrationAgingThresholdDays",
                  "imagetypNormalizationUserMappings",
                  "patternsByType",
                  "plannerMoonAvoidance"
                ]
              },
              {
                "type": "string",
                "pattern": "^tools\\.[a-z0-9_]+\\.bundle_id$"
              },
              {
                "type": "string",
                "pattern": "^workflow_profile\\.[a-z0-9_]+\\.watch_extensions$"
              },
              {
                "type": "string",
                "pattern": "^workflow_profile\\.[a-z0-9_]+\\.launch_attribution_window_hours$"
              }
            ]
          }
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "restored"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["success", "noop"],
              "description": "'success' when at least one key was restored (literal default value written). 'noop' when every requested key was already at its default value — no row writes, no audit events (R-3.1)."
            },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "restored": {
              "type": "array",
              "description": "Keys for which the literal default value was written. Empty when status='noop'.",
              "items": { "type": "string" }
            },
            "alreadyAtDefault": {
              "type": "array",
              "description": "Keys that were already at their default value and were not written (R-3.1).",
              "items": { "type": "string" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["key.unknown"]
        },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
