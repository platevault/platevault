{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan/contracts/settings.update.json",
  "title": "settings.update",
  "description": "Write a single settings key. Implements the no-op guard and emits a non-noisy audit event when value changes.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "key", "value"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" },
        "key": {
          "description": "Name of a v1 settings key, including structured-path keys.",
          "oneOf": [
            {
              "type": "string",
              "enum": [
                "pattern",
                "autoApplyPattern",
                "alwaysPreviewBeforePlan",
                "followSymlinks",
                "hashOnScan",
                "darkMatchTolerance",
                "flatMatching",
                "suggestCalibration",
                "rowDensity",
                "logLevel",
                "rememberFollowLogs",
                "defaultProtection",
                "blockPermanentDelete",
                "protectedCategories",
                "currentLibraryId",
                "devMode",
                "plansListDefaultAgeCutoffDays",
                "target_lookup.active_catalogs",
                "calibrationDarkTempTolerance",
                "calibrationPrefillSuggestion",
                "calibrationDarkOverridePenalty",
                "calibrationFlatOverridePenalty",
                "calibrationBiasOverridePenalty",
                "calibrationAgingThresholdDays",
                "imagetypNormalizationUserMappings",
                "patternsByType"
              ]
            },
            {
              "type": "string",
              "pattern": "^tools\\.[a-z0-9_]+\\.bundle_id$",
              "description": "Per-tool macOS bundle identifier key."
            },
            {
              "type": "string",
              "pattern": "^workflow_profile\\.[a-z0-9_]+\\.watch_extensions$",
              "description": "Per-workflow-profile watcher extension allow-list key."
            },
            {
              "type": "string",
              "pattern": "^workflow_profile\\.[a-z0-9_]+\\.launch_attribution_window_hours$",
              "description": "Per-workflow-profile tool launch attribution window key."
            }
          ]
        },
        "value": {
          "description": "Value to write. Must validate against the per-key sub-schema in settings.state.v1.json."
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "key", "priorValue", "newValue"],
          "properties": {
            "status": {
              "type": "string",
              "enum": ["success", "noop"],
              "description": "'success' when the value changed and was persisted. 'noop' when the incoming value is deep-equal to the stored value (A4, R4.1): no row write, no audit event. Matches spec 002 noop pattern."
            },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "key": { "type": "string" },
            "priorValue": {
              "description": "Value before the update. Equal to newValue when status='noop'."
            },
            "newValue": {
              "description": "Value after the update. Equal to priorValue when status='noop'."
            },
            "auditId": {
              "type": "string",
              "description": "Audit event id for non-noisy changes. Absent for noisy keys and when status='noop'."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["key.unknown", "value.invalid"]
        },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
