{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.dev/contracts/025/plan.resume.json",
  "title": "plan.resume",
  "description": "Resume a paused plan apply run. Re-validates the pause condition before resuming. If the condition is still present, returns failure with the appropriate code. Owned by spec 025. (R-Pause-1, R-Env-1)",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "planId", "runId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string" },
        "planId": {
          "type": "string",
          "description": "Identifier of the plan in state `paused`."
        },
        "runId": {
          "type": "string",
          "description": "Identifier of the PlanApplyRun to resume."
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "planId", "runId", "resumedAt"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "planId": { "type": "string" },
            "runId": { "type": "string" },
            "resumedAt": {
              "type": "string",
              "format": "date-time",
              "description": "Timestamp at which the run transitioned back to applying."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "run.not_found",
            "run.not_paused",
            "volume.still.unavailable",
            "disk.still.full",
            "item.still.stale"
          ],
          "description": "Server re-validates the pause condition before resuming. Returns the appropriate fault code if the condition is unresolved."
        },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    }
  }
}
