{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.dev/contracts/025/plan.apply.json",
  "title": "plan.apply",
  "description": "Apply an approved filesystem plan. Long-running operation: clients subscribe to itemProgress and planTerminal events with a cursor. Owned by spec 025. Plan generation/review/approve/discard live in spec 017. (R-Env-1, R-Run-1, R-CAS-1, R-FS-1)",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "planId", "approvalToken"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string" },
        "planId": {
          "type": "string",
          "description": "Identifier of the plan in state `approved`."
        },
        "approvalToken": {
          "type": "string",
          "description": "Token issued by spec 017's plan.approve, HMAC over (planId, contentHash, approvedAt, serverSecret). Single-use; no TTL — freshness via per-item FS revalidation (A1, R-FS-1)."
        },
        "cursor": {
          "type": "string",
          "description": "Optional resume cursor for re-subscribing to the same in-flight run.",
          "nullable": true
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "planId", "runId", "newState"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "planId": { "type": "string" },
            "runId": {
              "type": "string",
              "description": "Identifier of this PlanApplyRun row (mandatory in v1, R-Run-1)."
            },
            "newState": {
              "const": "applying",
              "description": "Plan state immediately after apply begins."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    },
    "events": {
      "type": "object",
      "description": "Stream events emitted to subscribers of this long-running operation.",
      "properties": {
        "itemProgress": {
          "type": "object",
          "additionalProperties": false,
          "required": ["runId", "planId", "itemId", "priorState", "newState", "at", "cursor"],
          "properties": {
            "runId": { "type": "string" },
            "planId": { "type": "string" },
            "itemId": { "type": "string" },
            "priorState": {
              "type": "string",
              "enum": ["pending", "applying", "succeeded", "failed", "stale", "skipped", "cancelled"]
            },
            "newState": {
              "type": "string",
              "enum": ["pending", "applying", "succeeded", "failed", "stale", "skipped", "cancelled"]
            },
            "at": { "type": "string", "format": "date-time" },
            "cursor": {
              "type": "string",
              "description": "Opaque cursor; resume subscription by passing it as request.cursor."
            },
            "failure": {
              "type": "object",
              "additionalProperties": false,
              "required": ["code", "message", "recoverable"],
              "properties": {
                "code": {
                  "type": "string",
                  "enum": [
                    "permission.denied",
                    "conflict.destination_exists",
                    "source.missing",
                    "source.locked",
                    "volume.unavailable",
                    "disk.full",
                    "path.invalid",
                    "protected.source",
                    "trash.unavailable",
                    "copy.succeeded.delete.failed",
                    "copy.succeeded.delete.failed.rollback.failed",
                    "item.stale",
                    "os_trash.unavailable",
                    "os_trash.full",
                    "os_trash.permission.denied",
                    "unknown"
                  ]
                },
                "message": { "type": "string" },
                "recoverable": { "type": "boolean" }
              }
            }
          }
        },
        "planTerminal": {
          "type": "object",
          "additionalProperties": false,
          "required": ["runId", "planId", "terminalState", "at", "counts"],
          "properties": {
            "runId": { "type": "string" },
            "planId": { "type": "string" },
            "terminalState": {
              "type": "string",
              "enum": ["applied", "partially_applied", "failed", "cancelled"]
            },
            "at": { "type": "string", "format": "date-time" },
            "counts": {
              "type": "object",
              "additionalProperties": false,
              "required": ["succeeded", "failed", "skipped", "cancelled"],
              "properties": {
                "succeeded": { "type": "integer", "minimum": 0 },
                "failed": { "type": "integer", "minimum": 0 },
                "skipped": { "type": "integer", "minimum": 0 },
                "cancelled": { "type": "integer", "minimum": 0 }
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "plan.not_found",
            "plan.not_approved",
            "plan.approval.stale",
            "plan.invalid_state",
            "plan.conflict.overlap"
          ],
          "description": "plan.invalid_state covers CAS race (R-CAS-1): state changed between read and write."
        },
        "message": { "type": "string" },
        "currentState": {
          "type": "string",
          "description": "Returned on plan.invalid_state and plan.not_approved."
        },
        "conflictingPlanId": {
          "type": "string",
          "description": "Returned on plan.conflict.overlap."
        },
        "details": { "type": "object" }
      }
    }
  }
}
