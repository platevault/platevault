{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.dev/contracts/025/plan.item.skip.json",
  "title": "plan.item.skip",
  "description": "Skip a still-pending plan item during an active apply. The item transitions from pending to skipped and is not executed. Owned by spec 025. (R-Env-1)",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "planId", "itemId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string" },
        "planId": { "type": "string" },
        "itemId": { "type": "string" }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "itemId", "newState"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "itemId": { "type": "string" },
            "newState": { "const": "skipped" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "plan.not_found",
            "plan.not_in_apply",
            "item.not_found",
            "item.not_pending"
          ]
        },
        "message": { "type": "string" },
        "currentItemState": {
          "type": "string",
          "description": "Returned on item.not_pending."
        },
        "details": { "type": "object" }
      }
    }
  }
}
