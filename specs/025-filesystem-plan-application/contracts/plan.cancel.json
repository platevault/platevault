{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.dev/contracts/025/plan.cancel.json",
  "title": "plan.cancel",
  "description": "Cancel an in-flight plan apply (from applying or paused state). The currently-applying item is allowed to finish; remaining pending items transition to cancelled. Owned by spec 025. (R-Env-1, E4)",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "planId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string" },
        "planId": { "type": "string" }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "planId", "cancelledAt", "itemsApplied", "itemsCancelled"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "planId": { "type": "string" },
            "cancelledAt": { "type": "string", "format": "date-time" },
            "itemsApplied": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of items that completed (succeeded or failed) before cancellation took effect."
            },
            "itemsCancelled": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of items that were still pending and were transitioned to cancelled. (E4: renamed from itemsPendingSkipped)"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["plan.not_found", "plan.not_in_apply", "plan.terminal"],
          "description": "plan.not_in_apply is returned when state is neither applying nor paused."
        },
        "message": { "type": "string" },
        "currentState": {
          "type": "string",
          "description": "Returned on plan.not_in_apply and plan.terminal."
        },
        "details": { "type": "object" }
      }
    }
  }
}
