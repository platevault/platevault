{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/project.list.json",
  "title": "project.list",
  "description": "Project list read contract. Returns ProjectSummary records for the projects page. Filters are AND-composed; omitted filters mean 'no constraint'.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "1.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "ProjectLifecycle": {
      "type": "string",
      "enum": [
        "setup_incomplete",
        "ready",
        "prepared",
        "processing",
        "completed",
        "archived",
        "blocked"
      ]
    },
    "ProcessingTool": {
      "type": "string",
      "enum": ["PixInsight", "Siril", "Planetary Suite"]
    },
    "BlockedReason": {
      "type": "object",
      "required": ["kind"],
      "additionalProperties": true,
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "source_missing",
            "prepared_source_stale",
            "tool_unconfigured",
            "calibration_unmatched",
            "user"
          ]
        },
        "note": { "type": "string" }
      }
    },
    "LastAction": {
      "type": "object",
      "required": ["label", "when"],
      "additionalProperties": false,
      "properties": {
        "label": { "type": "string", "minLength": 1, "maxLength": 120 },
        "when": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "ProjectSummary": {
      "type": "object",
      "required": ["id", "name", "lifecycle", "tool", "sourceCount", "channels"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/Uuid" },
        "name": { "type": "string", "minLength": 1 },
        "lifecycle": { "$ref": "#/$defs/ProjectLifecycle" },
        "tool": { "$ref": "#/$defs/ProcessingTool" },
        "sourceCount": { "type": "integer", "minimum": 0 },
        "channels": { "type": "array", "items": { "type": "string" } },
        "blockedReason": { "$ref": "#/$defs/BlockedReason" },
        "lastAction": { "$ref": "#/$defs/LastAction" }
      },
      "allOf": [
        {
          "if": { "properties": { "lifecycle": { "const": "blocked" } } },
          "then": { "required": ["blockedReason"] }
        }
      ]
    },
    "ErrorCode": {
      "type": "string",
      "enum": ["filter.invalid", "actor.not_authorised"]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "lifecycle_filter": {
          "type": "array",
          "description": "Multiselect lifecycle filter. Empty array or omitted means 'all'.",
          "items": { "$ref": "#/$defs/ProjectLifecycle" },
          "uniqueItems": true
        },
        "tool_filter": {
          "type": "array",
          "description": "Multiselect tool filter. Empty array or omitted means 'all'.",
          "items": { "$ref": "#/$defs/ProcessingTool" },
          "uniqueItems": true
        },
        "cursor": {
          "type": "string",
          "description": "Opaque pagination cursor returned by a prior response in nextCursor. Omit to start from the first page. Format: base64-encoded (createdAt, id) tuple — treat as opaque; format may change between server versions (R-Pagination, GRILL 2026-05-22)."
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200,
          "default": 50,
          "description": "Maximum number of projects to return. Default 50, max 200."
        }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "projects": {
          "type": "array",
          "items": { "$ref": "#/$defs/ProjectSummary" }
        },
        "nextCursor": {
          "type": "string",
          "description": "Opaque cursor for the next page. Absent when this is the last page. Pass this value as 'cursor' in the next request to continue pagination (R-Pagination, GRILL 2026-05-22)."
        },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["projects"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
