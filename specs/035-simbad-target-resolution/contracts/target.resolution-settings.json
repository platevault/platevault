{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/target.resolution-settings.json",
  "title": "target.resolution.settings",
  "description": "Get/update the SIMBAD resolver settings (spec 035). Replaces the spec-014 catalog manifest/signing settings surface. Singleton.",
  "type": "object",
  "oneOf": [ { "$ref": "#/$defs/GetRequest" }, { "$ref": "#/$defs/UpdateRequest" }, { "$ref": "#/$defs/Response" } ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "1.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Settings": {
      "type": "object",
      "required": ["onlineEnabled", "simbadEndpoint", "debounceMs", "requestTimeoutSecs"],
      "additionalProperties": false,
      "properties": {
        "onlineEnabled": { "type": "boolean", "description": "Enable/disable online SIMBAD resolution (FR-015; default true). When false, only seed+cache are used." },
        "simbadEndpoint": { "type": "string", "format": "uri" },
        "debounceMs": { "type": "integer", "minimum": 0, "default": 300 },
        "requestTimeoutSecs": { "type": "integer", "minimum": 1, "default": 10 }
      }
    },
    "GetRequest": {
      "type": "object",
      "required": ["contractVersion", "requestId", "op"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "op": { "const": "get" }
      }
    },
    "UpdateRequest": {
      "type": "object",
      "required": ["contractVersion", "requestId", "op", "settings"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "op": { "const": "update" },
        "settings": { "$ref": "#/$defs/Settings" }
      }
    },
    "Response": {
      "type": "object",
      "required": ["contractVersion", "requestId", "settings"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "settings": { "$ref": "#/$defs/Settings" }
      }
    }
  }
}
