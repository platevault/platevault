{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/project.manifest.get.json",
  "title": "project.manifest.get",
  "description": "Fetch one manifest snapshot with its full structured body.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "2.0.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "ManifestReason": {
      "type": "string",
      "enum": [
        "created",
        "source_change",
        "lifecycle_transition",
        "cleanup_applied",
        "workflow_run"
      ]
    },
    "ManifestBody": {
      "type": "object",
      "required": ["lifecycleState", "sourceMap"],
      "properties": {
        "sourceMap": {
          "type": "object",
          "description": "Snapshot of selected Inventory items by role.",
          "additionalProperties": true
        },
        "calibration": {
          "type": "object",
          "description": "Calibration choices and reused masters.",
          "additionalProperties": true
        },
        "workflowProfile": {
          "type": ["string", "null"]
        },
        "generatedViews": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "path"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "path": { "type": "string" }
            }
          }
        },
        "lifecycleState": { "type": "string" },
        "notes": {
          "type": ["string", "null"],
          "description": "Snapshot of the project's notes body at generation time."
        }
      }
    },
    "Manifest": {
      "type": "object",
      "required": [
        "id",
        "projectId",
        "reason",
        "timestamp",
        "path",
        "version",
        "body"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "reason": { "$ref": "#/$defs/ManifestReason" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "path": { "type": "string" },
        "version": { "type": "integer", "minimum": 1 },
        "body": { "$ref": "#/$defs/ManifestBody" }
      }
    },
    "ErrorCode": {
      "type": "string",
      "enum": ["manifest.not_found"]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "manifestId"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "manifestId": { "type": "string" }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "manifest": { "$ref": "#/$defs/Manifest" },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["manifest"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
