{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/project.manifest.list.json",
  "title": "project.manifest.list",
  "description": "List manifest snapshots for a project, ordered newest first.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "2.0.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "ManifestReason": {
      "type": "string",
      "enum": [
        "created",
        "source_change",
        "lifecycle_transition",
        "cleanup_applied",
        "workflow_run"
      ]
    },
    "ManifestSummary": {
      "type": "object",
      "required": ["id", "reason", "timestamp", "path", "hasBody"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "reason": { "$ref": "#/$defs/ManifestReason" },
        "timestamp": { "$ref": "#/$defs/Timestamp" },
        "path": {
          "type": "string",
          "description": "Project-relative path, typically under notes/."
        },
        "hasBody": {
          "type": "boolean",
          "description": "True when the manifest carries an expandable body."
        }
      }
    },
    "ErrorCode": {
      "type": "string",
      "enum": ["project.not_found"]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "projectId"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "projectId": {
          "type": "string",
          "description": "Identifier of the project whose manifests to list."
        },
        "cursor": {
          "type": "string",
          "description": "Opaque pagination cursor from a previous response. Omit for first page."
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 200,
          "default": 50,
          "description": "Maximum number of manifests to return. Default 50, max 200."
        }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "manifests": {
          "type": "array",
          "items": { "$ref": "#/$defs/ManifestSummary" }
        },
        "nextCursor": {
          "type": "string",
          "description": "Opaque cursor to retrieve the next page. Absent when no further results."
        },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["manifests"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
