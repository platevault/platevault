{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/project.note.update.json",
  "title": "project.note.update",
  "description": "Replace the project's notes body with the provided content.",
  "type": "object",
  "properties": {
    "operation": { "const": "project.note.update" },
    "request": {
      "type": "object",
      "required": ["project_id", "content"],
      "additionalProperties": false,
      "properties": {
        "project_id": { "type": "string" },
        "content": {
          "type": "string",
          "maxLength": 16384,
          "description": "Full replacement markdown body (UTF-8). Empty string clears the notes. Maximum 16 384 bytes UTF-8 (A5)."
        }
      }
    },
    "response": {
      "type": "object",
      "required": ["updated_at"],
      "additionalProperties": false,
      "properties": {
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "Server-recorded save timestamp."
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["code", "message"],
        "properties": {
          "code": {
            "type": "string",
            "enum": ["project.not_found", "project.read_only", "note.content_too_large"]
          },
          "description_note": "project.read_only fires only when lifecycle == 'archived' (R-NotesEdit). note.content_too_large fires when content exceeds 16 384 bytes UTF-8 (A5).",
          "message": { "type": "string" }
        }
      }
    }
  },
  "required": ["operation", "request", "response"]
}
