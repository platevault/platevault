{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/artifact.list.json",
  "title": "artifact.list",
  "description": "List processing artifacts observed under a project, grouped for the Tool Launches drawer accordion.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "2.0.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "ArtifactKind": {
      "type": "string",
      "enum": ["intermediate", "master", "final"]
    },
    "ArtifactState": {
      "type": "string",
      "enum": ["present", "missing", "user_resolved_missing"]
    },
    "Artifact": {
      "type": "object",
      "required": [
        "id",
        "projectId",
        "path",
        "kind",
        "tool",
        "detectedAt",
        "state",
        "classificationConfidence",
        "classificationSource"
      ],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "projectId": { "type": "string" },
        "toolLaunchId": {
          "type": ["string", "null"],
          "description": "Attribution to a tool launch from feature 011; null when no launch matched the detection window."
        },
        "path": {
          "type": "string",
          "description": "Project-relative path; resolved through the library root."
        },
        "kind": { "$ref": "#/$defs/ArtifactKind" },
        "tool": {
          "type": "string",
          "description": "Workflow-profile tool id, e.g. pixinsight or siril."
        },
        "detectedAt": { "$ref": "#/$defs/Timestamp" },
        "lastSeenAt": { "$ref": "#/$defs/Timestamp" },
        "state": { "$ref": "#/$defs/ArtifactState" },
        "classificationConfidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "classificationSource": {
          "type": "string",
          "enum": ["rule", "manual_override", "fallback"]
        },
        "sizeBytes": { "type": "integer", "minimum": 0 }
      }
    },
    "ErrorCode": {
      "type": "string",
      "enum": ["project.not_found", "project.output_folder_unavailable"]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "projectId"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "projectId": {
          "type": "string",
          "description": "Identifier of the project whose artifacts to list."
        },
        "includeStates": {
          "type": "array",
          "description": "Optional state filter. Defaults to ['present','missing'].",
          "items": { "$ref": "#/$defs/ArtifactState" },
          "uniqueItems": true
        }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "artifacts": {
          "type": "array",
          "items": { "$ref": "#/$defs/Artifact" }
        },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["artifacts"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
