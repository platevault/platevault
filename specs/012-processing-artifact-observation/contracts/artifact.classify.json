{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/artifact.classify.json",
  "title": "artifact.classify",
  "description": "Manually override the classification of a processing artifact. Override is sticky: subsequent automatic re-classifications respect it until cleared.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "2.0.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "ArtifactKind": {
      "type": "string",
      "enum": ["intermediate", "master", "final"]
    },
    "ErrorCode": {
      "type": "string",
      "enum": ["artifact.not_found", "artifact.kind_invalid", "project.read_only"]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "artifactId", "kind"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "artifactId": {
          "type": "string",
          "description": "Identifier of the artifact to override."
        },
        "kind": {
          "type": ["string", "null"],
          "enum": ["intermediate", "master", "final", null],
          "description": "User-asserted classification. Pass null to clear the manual override and re-apply workflow-profile rules (A6)."
        },
        "reason": {
          "type": "string",
          "maxLength": 500,
          "description": "Optional free-form note for the audit trail."
        }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "classified": {
          "type": "boolean",
          "description": "True when the override was applied."
        },
        "artifactId": { "type": "string" },
        "kind": { "$ref": "#/$defs/ArtifactKind" },
        "classificationSource": {
          "type": "string",
          "enum": ["manual_override"]
        },
        "classificationConfidence": {
          "type": "number",
          "const": 1.0
        },
        "updatedAt": { "$ref": "#/$defs/Timestamp" },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["classified", "artifactId", "kind", "classificationSource", "classificationConfidence"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
