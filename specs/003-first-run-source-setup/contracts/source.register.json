{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-library-manager.local/contracts/source.register.json",
  "title": "source.register",
  "description": "Register a single directory as a RegisteredSource of the given kind. Idempotent failure on duplicate (kind, path). Performs path existence, directory, and readability validation before inserting.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "kind", "path"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" },
        "kind": {
          "description": "Which source category this directory belongs to.",
          "type": "string",
          "enum": ["raw", "calibration", "project", "inbox"]
        },
        "path": {
          "description": "Absolute filesystem path to a readable directory on the local machine. OS-canonical form preferred; server will normalize.",
          "type": "string",
          "minLength": 1
        },
        "kindSubtype": {
          "description": "Optional category refinement (reserved; unused at first-run).",
          "type": "string"
        },
        "scanDepth": {
          "description": "How deep to scan this source root. Default 'recursive'. Exposed as advanced/collapsed disclosure in the wizard (R-Wiz-1).",
          "type": "string",
          "enum": ["recursive", "single"],
          "default": "recursive"
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "sourceId", "kind", "path", "createdAt"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "sourceId": {
              "type": "string",
              "format": "uuid"
            },
            "kind": {
              "type": "string",
              "enum": ["raw", "calibration", "project", "inbox"]
            },
            "path": {
              "type": "string",
              "description": "Normalized canonical path as persisted."
            },
            "createdAt": {
              "type": "string",
              "format": "date-time"
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "path.not_exists",
            "path.not_directory",
            "path.permission_denied",
            "kind.unsupported",
            "path.already_registered",
            "path.already_registered.different_kind"
          ]
        },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
