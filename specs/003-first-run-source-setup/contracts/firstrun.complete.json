{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-library-manager.local/contracts/firstrun.complete.json",
  "title": "firstrun.complete",
  "description": "Mark the first-run wizard as completed. MUST only succeed when the wizard is in_progress, at least one RegisteredSource of kind 'raw' exists, and at least one RegisteredSource of kind 'project' exists (R-Wiz-2). Source registration MUST be performed via source.register.batch before calling this operation (R-Batch, A9). Sets FirstRunState.completedAt and mirrors the completion flag to localStorage. Emits audit event first_run.completed (R-E2). Partial-success from the batch call is handled at the Finish step; this operation is only invoked after all required sources are committed.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "completedAt"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "completedAt": {
              "type": "string",
              "format": "date-time",
              "description": "Server-local time the wizard was marked complete."
            },
            "registeredSourceCount": {
              "type": "integer",
              "minimum": 0,
              "description": "Total RegisteredSource rows at completion time, included for caller convenience."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["wizard.not_in_progress", "required_step.incomplete"]
        },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
