{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan/contracts/guided.step.complete.json",
  "title": "guided.step.complete",
  "description": "Mark a guided flow step as complete and return the next step.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "stepId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" },
        "stepId": {
          "type": "string",
          "description": "Stable id of the step to mark complete (e.g. `inbox.confirm_first`)."
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "completed"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "completed": {
              "type": "boolean",
              "description": "True when this call transitioned the step into completedSteps."
            },
            "nextStep": {
              "type": ["string", "null"],
              "description": "Id of the next uncompleted step, or null when the flow is complete."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["unknown_step_id", "flow_dismissed", "persistence_unavailable"]
        },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
