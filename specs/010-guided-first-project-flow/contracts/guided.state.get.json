{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan/contracts/guided.state.get.json",
  "title": "guided.state.get",
  "description": "Return the current GuidedFlowState for UI hydration.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "state"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "state": { "$ref": "#/$defs/GuidedFlowState" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "GuidedFlowState": {
      "type": "object",
      "additionalProperties": false,
      "required": ["currentStep", "completedSteps", "dismissed"],
      "properties": {
        "currentStep": {
          "type": ["string", "null"],
          "description": "Id of the active step or null."
        },
        "completedSteps": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "dismissed": { "type": "boolean" },
        "dismissedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["persistence_unavailable", "state_corrupted"],
          "description": "state_corrupted is informational: it signals that corruption was detected, the row has already been reset to Idle server-side, and the caller should retry. The next call returns the fresh Idle state. persistence_unavailable signals a storage layer failure."
        },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
