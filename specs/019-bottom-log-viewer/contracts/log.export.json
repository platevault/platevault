{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan/contracts/log.export.json",
  "title": "log.export",
  "description": "Export a window of log entries to a JSON file at a user-chosen path. The format is fixed to JSON; the format field is retained for forward compatibility but is not surfaced as a user setting.",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "format", "filePath"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" },
        "filePath": {
          "type": "string",
          "description": "Absolute filesystem path of the export target. Parent directory must exist and be writable."
        },
        "format": {
          "type": "string",
          "enum": ["json"],
          "description": "Fixed to 'json' in v1. Reserved for forward compatibility; not surfaced as a user setting."
        },
        "levelMin": {
          "type": "string",
          "enum": ["debug", "info", "warn", "error"],
          "description": "Optional minimum severity bound. Defaults to debug."
        },
        "since": {
          "type": "string",
          "format": "date-time",
          "description": "Optional ISO-8601 lower bound on entry time (inclusive)."
        },
        "until": {
          "type": "string",
          "format": "date-time",
          "description": "Optional ISO-8601 upper bound on entry time (exclusive)."
        },
        "includeDiagnostics": {
          "type": "boolean",
          "description": "Include source = 'diagnostic' entries. Defaults to false for exports.",
          "default": false
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "filePath", "count"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "filePath": {
              "type": "string",
              "description": "Absolute path of the written file. Equal to the requested filePath on success."
            },
            "count": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of LogEntry rows written."
            },
            "bytes": {
              "type": "integer",
              "minimum": 0,
              "description": "Optional byte size of the written file."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["path.write.denied", "path.parent.missing", "range.invalid", "format.unsupported"]
        },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    }
  }
}
