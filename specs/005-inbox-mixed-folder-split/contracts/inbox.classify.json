{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/inbox.classify.json",
  "title": "inbox.classify",
  "description": "Classify an Inbox folder as single-type, mixed, or unclassified using metadata-derived evidence. Idempotent unless force_rescan is true.",
  "type": "object",
  "version": "1.0.0",
  "operation": "inbox.classify",
  "request": {
    "type": "object",
    "required": ["inbox_item_id"],
    "additionalProperties": false,
    "properties": {
      "inbox_item_id": {
        "type": "string",
        "description": "Stable identifier of the Inbox folder candidate."
      },
      "force_rescan": {
        "type": "boolean",
        "default": false,
        "description": "If true, invalidate cached metadata for this Inbox item and re-read headers from disk."
      }
    }
  },
  "response": {
    "type": "object",
    "required": ["inbox_item_id", "type", "confidence", "computed_at"],
    "additionalProperties": false,
    "properties": {
      "inbox_item_id": { "type": "string" },
      "type": {
        "type": "string",
        "enum": ["single_type", "mixed", "unclassified"]
      },
      "confidence": {
        "type": "number",
        "minimum": 0,
        "maximum": 1
      },
      "frame_type": {
        "type": "string",
        "enum": ["light", "dark", "bias", "flat", "dark_flat"],
        "description": "Present only when type == single_type."
      },
      "breakdown": {
        "type": "array",
        "description": "Present when type in {single_type, mixed}.",
        "items": {
          "type": "object",
          "required": ["kind", "count"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "type": "string",
              "enum": ["light", "dark", "bias", "flat", "dark_flat"]
            },
            "count": { "type": "integer", "minimum": 0 },
            "destination_preview": {
              "type": "string",
              "description": "Path preview produced by the active Naming & Structure pattern. Preview only; the canonical destination is resolved at plan generation time."
            },
            "sample_files": {
              "type": "array",
              "items": { "type": "string" },
              "maxItems": 10
            }
          }
        }
      },
      "unclassified_files": {
        "type": "array",
        "description": "Files whose confidence fell below the configured threshold. Surfaced as 'Needs review'.",
        "items": { "type": "string" }
      },
      "sample_files": {
        "type": "array",
        "description": "Representative filenames spanning the folder.",
        "items": { "type": "string" },
        "maxItems": 10
      },
      "computed_at": {
        "type": "string",
        "format": "date-time"
      }
    }
  },
  "errors": [
    {
      "code": "inbox.item.not_found",
      "description": "No InboxItem exists for the provided inbox_item_id.",
      "http_status_hint": 404
    },
    {
      "code": "metadata.unreadable",
      "description": "Folder is reachable but no file metadata could be read (permissions, corruption, missing mount).",
      "http_status_hint": 422,
      "data": {
        "type": "object",
        "properties": {
          "unreadable_count": { "type": "integer" },
          "total_count": { "type": "integer" }
        }
      }
    }
  ]
}
