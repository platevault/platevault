{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/project.channels.dismiss_drift.json",
  "title": "project.channels.dismiss_drift",
  "description": "Dismiss the channel-drift banner without re-inferring channels. Keeps all existing manual overrides (additions and removals) unchanged. Resets channelDrift.hasNewSources to false on project.get. Records a project_channel_drift_dismissed audit event to distinguish deliberate dismissal from a re-infer. Ratified: GRILL 2026-05-22 R-ChannelDrift. Convention: camelCase (A7 exception for new contracts).",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "1.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "ErrorCode": {
      "type": "string",
      "enum": [
        "project.not_found",
        "actor.not_authorised"
      ]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "description": "Channel drift dismiss request. Does not change channel list; only resets the hasNewSources flag.",
      "required": ["contractVersion", "requestId", "projectId"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "projectId": { "$ref": "#/$defs/Uuid" }
      }
    },
    "Response": {
      "type": "object",
      "description": "Channel drift dismiss response.",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "projectId": { "$ref": "#/$defs/Uuid" },
        "auditId": { "$ref": "#/$defs/Uuid" },
        "dismissedAt": { "$ref": "#/$defs/Timestamp" },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["projectId", "auditId", "dismissedAt"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
