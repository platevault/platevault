{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/project.update.json",
  "title": "project.update",
  "description": "Patch metadata-only fields on an existing project: name, tool, notes. Source list mutations go through project.source.add (and a future project.source.remove). Lifecycle transitions go through project.lifecycle.transition (spec 009). Calibration set assignments go through spec 007 contracts. Edits are refused when lifecycle == 'archived' (research R7).",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "1.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "ProcessingTool": {
      "type": "string",
      "enum": ["PixInsight", "Siril", "Planetary Suite"]
    },
    "FieldName": {
      "type": "string",
      "enum": ["name", "tool", "notes"]
    },
    "ErrorCode": {
      "type": "string",
      "description": "Project-update-scoped error codes layered on the spec 002 ErrorEnvelope.",
      "enum": [
        "project.not_found",
        "name.empty",
        "name.too_long",
        "name.duplicate",
        "tool.unknown",
        "tool.locked",
        "lifecycle.read_only",
        "no_op"
      ]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": {
          "type": "string",
          "description": "Human-readable explanation. MUST NOT include secrets or absolute filesystem paths."
        },
        "details": {
          "type": "object",
          "description": "Structured context. name.duplicate MUST include conflicting_project_id. lifecycle.read_only MUST include current_lifecycle. tool.locked MUST include current_lifecycle (the lifecycle states that lock tool changes are prepared, processing, completed, blocked — R-Tool-Lock).",
          "additionalProperties": true,
          "properties": {
            "conflicting_project_id": { "$ref": "#/$defs/Uuid" },
            "current_lifecycle": {
              "type": "string",
              "enum": [
                "setup_incomplete",
                "ready",
                "prepared",
                "processing",
                "completed",
                "archived",
                "blocked"
              ]
            }
          }
        }
      }
    },
    "Request": {
      "type": "object",
      "description": "Project metadata patch request. At least one of name/tool/notes MUST be supplied; an empty patch returns 'no_op'.",
      "required": ["contractVersion", "requestId", "project_id"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "project_id": { "$ref": "#/$defs/Uuid" },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "tool": { "$ref": "#/$defs/ProcessingTool" },
        "notes": {
          "type": "string",
          "maxLength": 4096,
          "description": "Set to empty string to clear; the field is never deleted, only overwritten."
        }
      },
      "anyOf": [
        { "required": ["name"] },
        { "required": ["tool"] },
        { "required": ["notes"] }
      ]
    },
    "Response": {
      "type": "object",
      "description": "Project update response.",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "project_id": { "$ref": "#/$defs/Uuid" },
        "fields_updated": {
          "type": "array",
          "items": { "$ref": "#/$defs/FieldName" },
          "uniqueItems": true,
          "description": "Subset of the requested fields that were actually changed. A field present in the request but identical to the stored value is omitted from this list."
        },
        "audit_id": { "$ref": "#/$defs/Uuid" },
        "updated_at": { "$ref": "#/$defs/Timestamp" },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["project_id", "fields_updated", "audit_id", "updated_at"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
