{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "astro-plan/contracts/pattern.resolve",
  "title": "pattern.resolve",
  "description": "Resolve a token pattern against a metadata bundle to produce a relative destination path. Applies Unicode normalization, OS character sanitization, path-traversal checks, reserved-name checks, and length caps.",
  "type": "object",
  "definitions": {
    "PatternPart": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "value"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["token", "separator"] },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "MetadataBundle": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target":     { "type": "string" },
        "filter":     { "type": "string" },
        "date":       { "type": "string", "description": "Local date YYYY-MM-DD in AcquisitionSession.observer_location.tz (solar-noon boundary per spec 023). Falls back to UTC date when observer_location is unset. (Ref: R-Date-1)" },
        "frame_type": {
          "type": "string",
          "enum": ["light", "dark", "flat", "bias", "dark_flat"],
          "description": "Per-file frame type. 'mixed' is NOT a valid value here — it is a folder-level classification result, not a per-file MetadataBundle field. (Ref: R-FrameEnum)"
        },
        "camera":     { "type": "string" },
        "exposure":   { "type": "string" },
        "gain":       { "type": "string" },
        "binning":    { "type": "string" },
        "set_temp":   { "type": "string" }
      }
    }
  },
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pattern", "metadata"],
      "properties": {
        "pattern": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/PatternPart" }
        },
        "metadata": { "$ref": "#/definitions/MetadataBundle" }
      }
    },
    "response": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relative_path", "missing_tokens"],
      "properties": {
        "relative_path": {
          "type": "string",
          "description": "Forward-slash relative path; never starts with a drive letter or root anchor."
        },
        "missing_tokens": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Token names that were substituted via fallback (including 'date' when observer_location was unavailable)."
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Non-fatal structural warnings (e.g. consecutive_separators, leading_separator)."
        }
      }
    },
    "errors": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pattern.invalid": {
          "description": "Resolved path violates path length limits: segment > 200 UTF-8 bytes or total relative path > 200 chars. (Ref: A4)",
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "const": "pattern.invalid" },
            "message": { "type": "string" },
            "details": {
              "type": "object",
              "properties": {
                "violating_chars": { "type": "array", "items": { "type": "string" } },
                "resolved_length": { "type": "integer" },
                "segment_length_bytes": { "type": "integer", "description": "UTF-8 byte length of the offending segment. (Ref: A4)" }
              }
            }
          }
        },
        "pattern.invalid.unicode": {
          "description": "A resolved token value contains Unicode confusables or disallowed characters (C0/C1 controls, format chars, bidi overrides). (Ref: A1)",
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "const": "pattern.invalid.unicode" },
            "message": { "type": "string" },
            "details": {
              "type": "object",
              "properties": {
                "token": { "type": "string", "description": "The token whose value triggered the error." },
                "offending_value": { "type": "string" }
              }
            }
          }
        },
        "path.traversal": {
          "description": "A resolved token value is '.' or '..', or the assembled path contains a '..' segment. (Ref: A2)",
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "const": "path.traversal" },
            "message": { "type": "string" },
            "details": {
              "type": "object",
              "properties": {
                "offending_segment": { "type": "string" }
              }
            }
          }
        },
        "path.reserved_name": {
          "description": "A path segment matches a Windows reserved device name (CON, PRN, AUX, NUL, COM1-9, LPT1-9), case-insensitively, on any platform. (Ref: A3)",
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "const": "path.reserved_name" },
            "message": { "type": "string" },
            "details": {
              "type": "object",
              "properties": {
                "offending_segment": { "type": "string" }
              }
            }
          }
        },
        "token.unknown": {
          "description": "Pattern references a token name not present in the registry.",
          "type": "object",
          "required": ["code", "message"],
          "properties": {
            "code": { "const": "token.unknown" },
            "message": { "type": "string" },
            "details": {
              "type": "object",
              "properties": {
                "token": { "type": "string" }
              }
            }
          }
        }
      }
    }
  },
  "required": ["request", "response", "errors"]
}
