{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/pattern.preview.json",
  "title": "pattern.preview",
  "description": "Resolve a token pattern against a sample metadata bundle to produce a live preview path. Used by Settings UI to render a human-readable example such as 'Andromeda/Light/2026-05-22/L_001.fits' without side effects. Applies the same validation and sanitization pipeline as pattern.resolve. (Ref: R-Preview)",
  "contractVersion": "1.0.0",
  "operation": "pattern.preview",
  "request": {
    "type": "object",
    "required": ["contractVersion", "requestId", "pattern", "sampleMetadata"],
    "additionalProperties": false,
    "properties": {
      "contractVersion": {
        "type": "string",
        "const": "1.0.0"
      },
      "requestId": {
        "type": "string",
        "description": "Caller-supplied correlation ID."
      },
      "pattern": {
        "type": "array",
        "minItems": 1,
        "description": "The pattern to preview, as an ordered list of PatternPart objects.",
        "items": {
          "type": "object",
          "required": ["id", "kind", "value"],
          "additionalProperties": false,
          "properties": {
            "id": { "type": "string", "minLength": 1 },
            "kind": { "type": "string", "enum": ["token", "separator"] },
            "value": { "type": "string", "minLength": 1 }
          }
        }
      },
      "sampleMetadata": {
        "type": "object",
        "description": "Sample metadata bundle keyed by token source_field. Used to render a representative resolved path in the UI.",
        "additionalProperties": false,
        "properties": {
          "target":     { "type": "string" },
          "filter":     { "type": "string" },
          "date":       { "type": "string", "description": "Local date YYYY-MM-DD (Ref: R-Date-1)" },
          "frame_type": {
            "type": "string",
            "enum": ["light", "dark", "flat", "bias", "dark_flat"],
            "description": "Per-file frame type (Ref: R-FrameEnum)"
          },
          "camera":     { "type": "string" },
          "exposure":   { "type": "string" },
          "gain":       { "type": "string" },
          "binning":    { "type": "string" },
          "set_temp":   { "type": "string" }
        }
      }
    }
  },
  "response": {
    "oneOf": [
      {
        "type": "object",
        "required": ["contractVersion", "requestId", "status", "resolvedPath", "missingTokens", "warnings"],
        "additionalProperties": false,
        "properties": {
          "contractVersion": { "type": "string" },
          "requestId": { "type": "string" },
          "status": { "type": "string", "const": "success" },
          "resolvedPath": {
            "type": "string",
            "description": "The resolved relative path for display. Example: 'Andromeda/Light/2026-05-22/L_001.fits'."
          },
          "missingTokens": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Token names resolved via fallback. Shown in preview UI as dim segments."
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "consecutive_separators",
                "leading_separator",
                "trailing_separator",
                "no_path_separator"
              ]
            }
          }
        }
      },
      {
        "type": "object",
        "required": ["contractVersion", "requestId", "status", "errors"],
        "additionalProperties": false,
        "properties": {
          "contractVersion": { "type": "string" },
          "requestId": { "type": "string" },
          "status": { "type": "string", "const": "failure" },
          "errors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["code", "message"],
              "additionalProperties": false,
              "properties": {
                "code": {
                  "type": "string",
                  "enum": [
                    "pattern.empty",
                    "pattern.invalid",
                    "pattern.invalid.unicode",
                    "path.traversal",
                    "path.reserved_name",
                    "token.unknown"
                  ]
                },
                "message": { "type": "string" },
                "details": {
                  "type": "object",
                  "description": "Error-specific details. For pattern.invalid: includes resolvedLength (int) and segmentLengthBytes (int). For pattern.invalid.unicode: includes token (string) and offendingValue (string). For path.traversal and path.reserved_name: includes offendingSegment (string). For token.unknown: includes token (string)."
                }
              }
            }
          }
        }
      }
    ]
  }
}
