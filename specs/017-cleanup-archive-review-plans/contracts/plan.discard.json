{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.dev/contracts/017/plan.discard.json",
  "title": "plan.discard",
  "description": "Soft-delete a plan (sets discardedAt; row retained; parentPlanId references resolvable). Refused while the plan is applying or paused. Owned by spec 017. (A5, R-Env-1)",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "planId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string" },
        "planId": { "type": "string" }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "planId", "discardedAt"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "planId": { "type": "string" },
            "discardedAt": {
              "type": "string",
              "format": "date-time",
              "description": "Timestamp at which the plan was soft-deleted (A5)."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["plan.not_found", "plan.in_progress"],
          "description": "plan.in_progress is returned when state is applying or paused."
        },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    }
  }
}
