{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.dev/contracts/017/plan.get.json",
  "title": "plan.get",
  "description": "Fetch a single plan with its items for the detail surface. Owned by spec 017. (R-Env-1: camelCase envelope, contractVersion, requestId, status-discriminated.)",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "planId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string" },
        "planId": { "type": "string" }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "plan"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "plan": { "$ref": "#/$defs/Plan" }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["plan.not_found"]
        },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    },
    "PlanItem": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "index",
        "name",
        "action",
        "from",
        "to",
        "reason",
        "protection",
        "state"
      ],
      "properties": {
        "id": { "type": "string" },
        "index": { "type": "integer", "minimum": 1 },
        "name": { "type": "string" },
        "action": {
          "type": "string",
          "enum": ["move", "archive", "delete", "link", "write"]
        },
        "from": { "type": "string" },
        "to": { "type": "string" },
        "reason": { "type": "string" },
        "protection": { "type": "string", "enum": ["normal", "protected"] },
        "linked": { "type": "string" },
        "state": {
          "type": "string",
          "enum": ["pending", "applying", "succeeded", "failed", "skipped", "cancelled"],
          "description": "cancelled added per E5."
        },
        "failureReason": { "type": "string" },
        "approvedMtime": {
          "type": "string",
          "format": "date-time",
          "description": "Source mtime snapshot taken at approve time (R-FS-1). Null before approval."
        },
        "approvedSizeBytes": {
          "type": "integer",
          "minimum": 0,
          "description": "Source size snapshot taken at approve time (R-FS-1). Null before approval."
        },
        "archivePath": {
          "type": "string",
          "description": "Computed destination under .astro-plan-archive/<planId>/ for destructive items (R-Archive-1)."
        },
        "provenance": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "value"],
            "properties": {
              "label": { "type": "string" },
              "value": { "type": "string" }
            }
          }
        }
      }
    },
    "Plan": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "number",
        "title",
        "origin",
        "state",
        "createdAt",
        "items",
        "itemsTotal",
        "itemsApplied",
        "itemsFailed",
        "itemsSkipped",
        "itemsCancelled",
        "itemsPending",
        "totalBytesRequired",
        "destructiveDestination",
        "type"
      ],
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "integer" },
        "title": { "type": "string" },
        "origin": {
          "type": "string",
          "enum": ["inbox", "restructure", "cleanup", "archive", "project"]
        },
        "originPath": { "type": "string" },
        "state": {
          "type": "string",
          "enum": [
            "draft",
            "ready_for_review",
            "approved",
            "applying",
            "paused",
            "applied",
            "partially_applied",
            "failed",
            "cancelled",
            "discarded"
          ]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "discardedAt": { "type": "string", "format": "date-time", "description": "Set when state == discarded (A5)." },
        "items": {
          "type": "array",
          "items": { "$ref": "#/$defs/PlanItem" }
        },
        "itemsTotal": { "type": "integer", "minimum": 0 },
        "itemsApplied": { "type": "integer", "minimum": 0 },
        "itemsFailed": { "type": "integer", "minimum": 0 },
        "itemsSkipped": { "type": "integer", "minimum": 0, "description": "A3." },
        "itemsCancelled": { "type": "integer", "minimum": 0, "description": "A3." },
        "itemsPending": { "type": "integer", "minimum": 0 },
        "totalBytesRequired": {
          "type": "integer",
          "minimum": 0,
          "description": "Pre-flight space estimate in bytes (A4)."
        },
        "destructiveDestination": {
          "type": "string",
          "enum": ["archive", "trash"],
          "description": "Per-plan destination for destructive items (R-Trash-1)."
        },
        "type": {
          "type": "string",
          "enum": ["split", "restructure", "cleanup", "archive", "source_map"]
        },
        "parentPlanId": { "type": "string" }
      }
    }
  }
}
