{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.dev/contracts/017/archive.send_to_trash.json",
  "title": "archive.send_to_trash",
  "description": "Send the entire app-managed archive subfolder for a plan (<library_root>/.astro-plan-archive/<planId>/) to the OS-native trash. Per-plan only. Emits an audit event. Owned by spec 017. (R-Archive-2, R-Env-1)",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "planId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string" },
        "planId": {
          "type": "string",
          "description": "The plan whose .astro-plan-archive/<planId>/ subtree is sent to trash."
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "planId", "itemsMoved", "auditId"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "planId": { "type": "string" },
            "itemsMoved": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of archived items (files) moved to OS trash."
            },
            "auditId": {
              "type": "string",
              "description": "Id of the audit event written for this operation."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "plan.not_found",
            "archive.empty",
            "os_trash.unavailable",
            "os_trash.permission.denied"
          ]
        },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    }
  }
}
