{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.dev/contracts/017/plan.list.json",
  "title": "plan.list",
  "description": "List reviewable plans, defaulting to failed-first ordering. Owned by spec 017. (R-Env-1: camelCase envelope, contractVersion, requestId, status-discriminated.)",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "type": "string", "description": "Contract version, e.g. \"1\"." },
        "requestId": { "type": "string", "description": "Caller-supplied correlation id." },
        "stateFilter": {
          "type": "array",
          "description": "Optional state allowlist; omit or empty for all non-discarded states.",
          "items": {
            "type": "string",
            "enum": [
              "draft",
              "ready_for_review",
              "approved",
              "applying",
              "paused",
              "applied",
              "partially_applied",
              "failed",
              "cancelled",
              "discarded"
            ]
          },
          "uniqueItems": true
        },
        "originFilter": {
          "type": "array",
          "description": "Optional origin allowlist; omit or empty for all origins.",
          "items": {
            "type": "string",
            "enum": ["inbox", "restructure", "cleanup", "archive", "project"]
          },
          "uniqueItems": true
        },
        "createdAfter": {
          "type": "string",
          "format": "date-time",
          "description": "Optional RFC 3339 cutoff. Server derives default from settings.plans.list.default_age_cutoff_days (default 90 days) when caller omits. (R-Ret-1)"
        },
        "limit": {
          "type": "integer",
          "minimum": 1,
          "maximum": 500,
          "default": 100
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "plans"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "plans": {
              "type": "array",
              "items": { "$ref": "#/$defs/PlanSummary" }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    },
    "PlanSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "number",
        "title",
        "origin",
        "state",
        "createdAt",
        "itemsTotal",
        "itemsApplied",
        "itemsFailed",
        "itemsSkipped",
        "itemsCancelled",
        "itemsPending",
        "totalBytesRequired",
        "destructiveDestination",
        "type"
      ],
      "properties": {
        "id": { "type": "string" },
        "number": { "type": "integer" },
        "title": { "type": "string" },
        "origin": {
          "type": "string",
          "enum": ["inbox", "restructure", "cleanup", "archive", "project"]
        },
        "originPath": { "type": "string" },
        "state": {
          "type": "string",
          "enum": [
            "draft",
            "ready_for_review",
            "approved",
            "applying",
            "paused",
            "applied",
            "partially_applied",
            "failed",
            "cancelled",
            "discarded"
          ]
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "discardedAt": { "type": "string", "format": "date-time", "description": "Set when state == discarded (A5)." },
        "itemsTotal": { "type": "integer", "minimum": 0 },
        "itemsApplied": { "type": "integer", "minimum": 0 },
        "itemsFailed": { "type": "integer", "minimum": 0 },
        "itemsSkipped": { "type": "integer", "minimum": 0, "description": "Items marked skipped during apply (A3)." },
        "itemsCancelled": { "type": "integer", "minimum": 0, "description": "Items cancelled when run was cancelled (A3)." },
        "itemsPending": { "type": "integer", "minimum": 0 },
        "totalBytesRequired": {
          "type": "integer",
          "minimum": 0,
          "description": "Pre-flight space estimate in bytes (A4)."
        },
        "destructiveDestination": {
          "type": "string",
          "enum": ["archive", "os_trash"],
          "description": "Per-plan destination for destructive items (R-Trash-1). Default: archive."
        },
        "type": {
          "type": "string",
          "enum": ["split", "restructure", "cleanup", "archive", "source_map"]
        },
        "parentPlanId": { "type": "string" }
      }
    }
  }
}
