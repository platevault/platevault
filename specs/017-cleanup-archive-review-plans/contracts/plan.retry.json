{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.dev/contracts/017/plan.retry.json",
  "title": "plan.retry",
  "description": "Create a new plan covering the failed items (or all items, or cancelled items) of a terminal parent plan. The new plan starts in draft. Default itemsFilter is 'failed'. For cancelled plans, the UI offers separate 'Retry failed' and 'Retry cancelled' CTAs. Owned by spec 017. (R-Retry-1, R-Env-1)",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "parentPlanId", "itemsFilter"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string" },
        "parentPlanId": { "type": "string" },
        "itemsFilter": {
          "type": "string",
          "enum": ["failed", "cancelled", "all"],
          "description": "Which parent items to materialise into the retry plan. Default: 'failed'. For cancelled plans, UI provides separate CTAs for 'failed' vs 'cancelled' (R-Retry-1)."
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "newPlanId", "parentPlanId", "itemsTotal"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "newPlanId": { "type": "string" },
            "parentPlanId": { "type": "string" },
            "itemsTotal": { "type": "integer", "minimum": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["parent.not_found", "parent.not_terminal", "no.items.to.retry"]
        },
        "message": { "type": "string" },
        "parentState": {
          "type": "string",
          "description": "Returned on parent.not_terminal so the UI can explain."
        },
        "details": { "type": "object" }
      }
    }
  }
}
