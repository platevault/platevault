{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.dev/contracts/017/plan.approve.json",
  "title": "plan.approve",
  "description": "Move a plan from ready_for_review (or draft) to approved. Computes and stores per-item FS snapshot (approvedMtime, approvedSizeBytes) and issues an approvalToken. Owned by spec 017. Apply itself is owned by spec 025. (A1, R-FS-1, R-Env-1)",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "planId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string" },
        "planId": { "type": "string" }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "planId", "newState", "approvalToken", "approvedAt"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "planId": { "type": "string" },
            "newState": { "const": "approved" },
            "approvalToken": {
              "type": "string",
              "description": "HMAC over (planId, contentHash, approvedAt, serverSecret). Single-use; consumed by spec 025's plan.apply. No time-based TTL; freshness enforced by per-item FS revalidation at apply time (A1, R-FS-1)."
            },
            "approvedAt": {
              "type": "string",
              "format": "date-time",
              "description": "Timestamp at which approval and the per-item snapshot were taken."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": ["plan.not_found", "plan.invalid_state", "plan.items.empty"]
        },
        "message": { "type": "string" },
        "currentState": {
          "type": "string",
          "description": "Returned on plan.invalid_state to help the UI explain the rejection."
        },
        "details": { "type": "object" }
      }
    }
  }
}
