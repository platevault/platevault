{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.dev/contracts/017/archive.permanently_delete.json",
  "title": "archive.permanently_delete",
  "description": "Permanently and irreversibly delete the entire app-managed archive subfolder for a plan (<library_root>/.astro-plan-archive/<planId>/). Requires confirmText == \"DELETE\" to gate this irreversible action. Emits an audit event. Owned by spec 017. (R-Archive-2, R-Env-1)",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "planId", "confirmText"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string" },
        "planId": {
          "type": "string",
          "description": "The plan whose .astro-plan-archive/<planId>/ subtree is permanently deleted."
        },
        "confirmText": {
          "type": "string",
          "const": "DELETE",
          "description": "Must be exactly the string \"DELETE\" to confirm this irreversible action. Any other value results in confirm.text.mismatch error."
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "planId", "itemsDeleted", "auditId"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "planId": { "type": "string" },
            "itemsDeleted": {
              "type": "integer",
              "minimum": 0,
              "description": "Number of archived items (files) permanently deleted."
            },
            "auditId": {
              "type": "string",
              "description": "Id of the audit event written for this operation."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "plan.not_found",
            "archive.empty",
            "confirm.text.mismatch",
            "path.permission.denied"
          ]
        },
        "message": { "type": "string" },
        "details": { "type": "object" }
      }
    }
  }
}
