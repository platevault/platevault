{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/target.get.json",
  "title": "target.get",
  "description": "Read contract for the Target detail aggregate. Returns the Target record plus joined session and project history. Sessions with null captured_on (observer_location unreviewed) are excluded from the sessions array (R-3.1).",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "1.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "Date": { "type": "string", "format": "date" },
    "ProjectLifecycle": {
      "type": "string",
      "enum": [
        "setup_incomplete",
        "ready",
        "prepared",
        "processing",
        "completed",
        "archived",
        "blocked"
      ],
      "description": "Canonical enum from spec 002/009. A contract snapshot test (X-2) should assert this enum does not drift from spec 009."
    },
    "ProcessingTool": {
      "type": "string",
      "enum": ["PixInsight", "Siril", "Planetary Suite"]
    },
    "CatalogId": {
      "type": "string",
      "enum": [
        "messier",
        "caldwell",
        "sharpless",
        "abell_pn",
        "abell_galaxies",
        "arp",
        "vdb",
        "barnard",
        "lbn",
        "ldn",
        "melotte",
        "common",
        "openngc"
      ],
      "description": "Closed enum of v1 catalog slugs (R-1.4). Ref: spec 014 catalog set."
    },
    "CatalogRef": {
      "type": "object",
      "required": ["catalog_id", "catalog_display", "designation"],
      "additionalProperties": false,
      "properties": {
        "catalog_id": { "$ref": "#/$defs/CatalogId" },
        "catalog_display": { "type": "string", "minLength": 1 },
        "designation": { "type": "string", "minLength": 1 }
      }
    },
    "Target": {
      "type": "object",
      "required": ["id", "primary_designation", "aliases", "catalog_refs", "created_at", "updated_at"],
      "additionalProperties": false,
      "properties": {
        "id": { "$ref": "#/$defs/Uuid" },
        "primary_designation": {
          "type": "string",
          "minLength": 1,
          "description": "Canonical display name (e.g. 'M 31'). Unique within the library. (R-1.3)"
        },
        "aliases": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "catalog_refs": {
          "type": "array",
          "items": { "$ref": "#/$defs/CatalogRef" }
        },
        "notes": {
          "type": "string",
          "description": "Per-target free text. Max 16 KB UTF-8 bytes (A6)."
        },
        "created_at": { "$ref": "#/$defs/Timestamp" },
        "updated_at": { "$ref": "#/$defs/Timestamp" }
      }
    },
    "TargetSession": {
      "type": "object",
      "required": ["session_id", "inventory_id"],
      "additionalProperties": false,
      "properties": {
        "session_id": { "$ref": "#/$defs/Uuid" },
        "captured_on": {
          "$ref": "#/$defs/Date",
          "description": "Night of acquisition per R3 solar-noon formula. Absent when observer_location is null/unreviewed; such sessions are excluded from this array entirely (R-3.1)."
        },
        "filter": { "type": "string" },
        "exposure": { "type": "string" },
        "frames": { "type": "integer", "minimum": 0 },
        "inventory_id": { "$ref": "#/$defs/Uuid" }
      }
    },
    "TargetProject": {
      "type": "object",
      "required": ["project_id", "name", "lifecycle", "tool"],
      "additionalProperties": false,
      "properties": {
        "project_id": { "$ref": "#/$defs/Uuid" },
        "name": { "type": "string", "minLength": 1 },
        "lifecycle": { "$ref": "#/$defs/ProjectLifecycle" },
        "tool": {
          "$ref": "#/$defs/ProcessingTool",
          "description": "REQUIRED. v1 projects always have a tool because spec 008 R-Tool-Req makes tool mandatory at project creation. The prior optional treatment from spec 023 R-3.3 is explicitly OVERRIDDEN by spec 008 R-Tool-Req (GRILL 2026-05-22)."
        }
      }
    },
    "ErrorCode": {
      "type": "string",
      "enum": ["target.not_found", "actor.not_authorised"]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "target_id"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "target_id": { "$ref": "#/$defs/Uuid" }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "target": { "$ref": "#/$defs/Target" },
        "sessions": {
          "type": "array",
          "items": { "$ref": "#/$defs/TargetSession" },
          "description": "Reverse-chronological by captured_on. Sessions with null captured_on are excluded."
        },
        "projects": {
          "type": "array",
          "items": { "$ref": "#/$defs/TargetProject" }
        },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["target", "sessions", "projects"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
