{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/target.alias.add.json",
  "title": "target.alias.add",
  "description": "Write contract that appends an alias to a target. Returns added=true on success. Fails with alias.duplicate if the normalized alias is already attached to a different target.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "1.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "ErrorCode": {
      "type": "string",
      "enum": [
        "target.not_found",
        "alias.duplicate",
        "alias.invalid",
        "actor.not_authorised"
      ]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "description": "On alias.duplicate, includes conflicting_target_id."
        }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "target_id", "alias"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "target_id": { "$ref": "#/$defs/Uuid" },
        "alias": {
          "type": "string",
          "description": "User-supplied alias display form. Server normalizes for uniqueness check.",
          "minLength": 1,
          "maxLength": 200
        }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "added": {
          "type": "boolean",
          "description": "True if the alias was newly persisted; false if the alias already existed on this target (idempotent no-op)."
        },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["added"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
