{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/target.note.update.json",
  "title": "target.note.update",
  "description": "Write contract for the per-target free-text note. Replaces the existing note content with the supplied body.",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/Request" },
    { "$ref": "#/$defs/Response" }
  ],
  "$defs": {
    "ContractVersion": { "type": "string", "const": "1.0" },
    "Uuid": { "type": "string", "format": "uuid" },
    "Timestamp": { "type": "string", "format": "date-time" },
    "ErrorCode": {
      "type": "string",
      "enum": ["target.not_found", "note.too_long", "actor.not_authorised"]
    },
    "ErrorEnvelope": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": { "$ref": "#/$defs/ErrorCode" },
        "message": { "type": "string" },
        "details": { "type": "object", "additionalProperties": true }
      }
    },
    "Request": {
      "type": "object",
      "required": ["contractVersion", "requestId", "target_id", "content"],
      "additionalProperties": false,
      "properties": {
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "target_id": { "$ref": "#/$defs/Uuid" },
        "content": {
          "type": "string",
          "description": "Replacement note body. Empty string clears the note. Max 16384 UTF-8 bytes (A6).",
          "maxLength": 16384
        }
      }
    },
    "Response": {
      "type": "object",
      "required": ["status", "contractVersion", "requestId"],
      "additionalProperties": false,
      "properties": {
        "status": { "type": "string", "enum": ["success", "error"] },
        "contractVersion": { "$ref": "#/$defs/ContractVersion" },
        "requestId": { "$ref": "#/$defs/Uuid" },
        "updated_at": { "$ref": "#/$defs/Timestamp" },
        "error": { "$ref": "#/$defs/ErrorEnvelope" }
      },
      "allOf": [
        {
          "if": { "properties": { "status": { "const": "success" } } },
          "then": {
            "required": ["updated_at"],
            "not": { "required": ["error"] }
          }
        },
        {
          "if": { "properties": { "status": { "const": "error" } } },
          "then": { "required": ["error"] }
        }
      ]
    }
  }
}
