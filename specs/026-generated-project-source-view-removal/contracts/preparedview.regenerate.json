{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan.local/contracts/preparedview.regenerate.json",
  "title": "preparedview.regenerate",
  "description": "Create a reviewable filesystem plan that regenerates a previously prepared (and possibly removed) project source view from the canonical database. Removed views have an indefinite regenerable lifetime (A4). The response planId enters the standard spec 017/025 pipeline (approve → apply). All spec 017/025 error codes can surface during apply. Allowed only when the owning project lifecycle is setup_incomplete|ready|prepared|processing|blocked|completed; refused on archived with lifecycle.read_only (R-026-Lifecycle).",
  "type": "object",
  "properties": {
    "request": {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "requestId", "viewId"],
      "properties": {
        "contractVersion": { "type": "string" },
        "requestId": { "type": "string", "format": "uuid" },
        "viewId": {
          "type": "string",
          "format": "uuid",
          "description": "Identifier of the PreparedSourceView to regenerate."
        }
      }
    },
    "response": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "planId"],
          "properties": {
            "status": { "const": "success" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "planId": {
              "type": "string",
              "format": "uuid",
              "description": "Identifier of the produced ViewRegenerationPlan (a FilesystemPlan with origin prepared_view_regeneration). Regeneration always creates a new plan and never reuses a removal plan. The plan enters the standard spec 017/025 pipeline: approve then apply."
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["status", "contractVersion", "requestId", "errors"],
          "properties": {
            "status": { "const": "failure" },
            "contractVersion": { "type": "string" },
            "requestId": { "type": "string", "format": "uuid" },
            "errors": {
              "type": "array",
              "items": { "$ref": "#/$defs/Error" }
            }
          }
        }
      ]
    }
  },
  "required": ["request", "response"],
  "$defs": {
    "Error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "type": "string",
          "enum": [
            "view.not_found",
            "view.in_use",
            "view.mixed_kind",
            "view.unsupported_kind",
            "lifecycle.read_only"
          ]
        },
        "message": { "type": "string" },
        "details": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "allowedLifecycleStates": {
              "type": "array",
              "items": { "type": "string" },
              "description": "Lifecycle states in which this operation is permitted."
            }
          }
        }
      }
    }
  }
}
