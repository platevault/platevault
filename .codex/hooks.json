{
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "command": "bd codex-hook PostCompact",
            "statusMessage": "Scheduling Beads context refresh",
            "type": "command"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "python3 $(git rev-parse --show-toplevel)/.codex/hooks/speckit-dag-hooks/scripts/dispatcher.py $(git rev-parse --show-toplevel)/.codex/hooks/speckit-dag-hooks/scripts/nodes.json post",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": ".codex/hooks/code-intelligence/scripts/reindex-after-commit.sh",
            "if": "Bash(git commit*)",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": ".codex/hooks/hooks-quality/scripts/quality-edit-advisory.sh",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "apply_patch|Edit|Write|MultiEdit"
      },
      {
        "hooks": [
          {
            "command": ".codex/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": ".codex/hooks/speckit/scripts/speckit-task-commit-check.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": ".codex/hooks/speckit/scripts/speckit-task-issue-sync.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "apply_patch"
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "command": "bd codex-hook PreCompact",
            "statusMessage": "Checking Beads context",
            "type": "command"
          }
        ],
        "matcher": "manual|auto"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "python3 $(git rev-parse --show-toplevel)/.codex/hooks/speckit-dag-hooks/scripts/dispatcher.py $(git rev-parse --show-toplevel)/.codex/hooks/speckit-dag-hooks/scripts/nodes.json pre",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": ".codex/hooks/code-intelligence/scripts/code-discovery-steer.sh",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "Grep|Glob|Read"
      },
      {
        "hooks": [
          {
            "command": ".codex/hooks/hooks-quality/scripts/quality-before-commit.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": ".codex/hooks/release-please/scripts/release-please-guard.sh",
            "timeout": 10,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": ".codex/hooks/speckit/scripts/speckit-issue-close-guard.sh",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": ".codex/hooks/speckit/scripts/speckit-issue-label-guard.sh",
            "timeout": 30,
            "type": "command"
          },
          {
            "command": ".codex/hooks/speckit/scripts/speckit-pr-issue-refs.sh",
            "timeout": 30,
            "type": "command"
          }
        ],
        "matcher": "Bash"
      },
      {
        "hooks": [
          {
            "command": ".codex/hooks/agent-coder/scripts/coder-delegation-reminder.sh",
            "timeout": 3,
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "async": true,
            "command": ".codex/hooks/code-intelligence/scripts/codebase-index.sh",
            "statusMessage": "Indexing codebase...",
            "type": "command"
          }
        ],
        "matcher": "startup"
      },
      {
        "hooks": [
          {
            "command": "bd codex-hook SessionStart",
            "statusMessage": "Loading Beads context",
            "type": "command"
          }
        ],
        "matcher": "startup|resume|clear"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": ".codex/hooks/speckit/scripts/speckit-stop-gate.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": ".codex/hooks/steering-pragmatic/scripts/inject-working-style.sh",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": ".codex/hooks/code-intelligence/scripts/subagent-context-inject.sh",
            "timeout": 5,
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "python3 $(git rev-parse --show-toplevel)/.codex/hooks/speckit-dag-hooks/scripts/dispatcher.py $(git rev-parse --show-toplevel)/.codex/hooks/speckit-dag-hooks/scripts/nodes.json pre",
            "timeout": 5,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": ".codex/hooks/speckit/scripts/speckit-deferred-issues.sh",
            "timeout": 30,
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "command": "bd codex-hook UserPromptSubmit",
            "statusMessage": "Refreshing Beads context",
            "type": "command"
          }
        ]
      }
    ]
  }
}
