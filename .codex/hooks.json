{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".agents/skills/speckit-dag/scripts/dispatcher.sh",
            "args": [
              "pre"
            ],
            "timeout": 5
          }
        ],
        "_apm_source": "speckit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/speckit-dag-hooks/scripts/dispatcher.py .codex/hooks/speckit-dag-hooks/scripts/nodes.json pre",
            "timeout": 5
          }
        ],
        "_apm_source": "speckit-dag-hooks"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".agents/skills/speckit-dag/scripts/dispatcher.sh",
            "args": [
              "pre"
            ],
            "timeout": 5
          }
        ],
        "_apm_source": "speckit"
      },
      {
        "matcher": "apply_patch|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/agent-coder/scripts/coder-delegation-reminder.sh"
          }
        ],
        "_apm_source": "agent-coder"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/speckit-dag-hooks/scripts/dispatcher.py .codex/hooks/speckit-dag-hooks/scripts/nodes.json pre",
            "timeout": 5
          }
        ],
        "_apm_source": "speckit-dag-hooks"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/mcp-repomix/scripts/repomix-refresh-snapshot.sh",
            "if": "Bash(git switch -c*)|Bash(git switch --create*)|Bash(git checkout -b*)|Bash(git checkout -B*)|Bash(git worktree add*)|Bash(git merge*)|Bash(git pull*)|Bash(git rebase*)"
          }
        ],
        "_apm_source": "mcp-repomix"
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/speckit/scripts/speckit-task-commit-check.sh",
            "if": "Bash(git commit*)"
          }
        ],
        "_apm_source": "speckit"
      },
      {
        "matcher": "apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": ".codex/hooks/speckit/scripts/speckit-task-issue-sync.sh"
          }
        ],
        "_apm_source": "speckit"
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 .codex/hooks/speckit-dag-hooks/scripts/dispatcher.py .codex/hooks/speckit-dag-hooks/scripts/nodes.json post",
            "timeout": 5
          }
        ],
        "_apm_source": "speckit-dag-hooks"
      }
    ]
  }
}
