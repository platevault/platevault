{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://astro-plan/contracts/dev.calls.list.json",
  "title": "dev.calls.list",
  "description": "Read the in-memory recent-calls ring buffer captured by the developer-mode recording proxy. Only available in dev-tools builds. Session-only, never persisted.",
  "operation": {
    "name": "dev.calls.list",
    "direction": "ui-to-core",
    "version": "1",
    "contractVersion": "1.0.0"
  },
  "request": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "requestId": {
        "type": "string",
        "description": "Caller-supplied correlation id."
      },
      "limit": {
        "type": "integer",
        "minimum": 1,
        "maximum": 100,
        "description": "Optional max rows to return. Defaults to the full buffer (100). Larger values are clamped to 100."
      }
    }
  },
  "response": {
    "oneOf": [
      {
        "type": "object",
        "required": ["status", "requestId", "contractVersion", "calls"],
        "additionalProperties": false,
        "properties": {
          "status": { "type": "string", "const": "ok" },
          "requestId": { "type": "string" },
          "contractVersion": { "type": "string", "const": "1.0.0" },
          "calls": {
            "type": "array",
            "description": "Newest-first list of recorded calls. Paths are redacted by default (${LIBRARY_ROOT}/... placeholder). Sensitive fields (password/token/secret/api_key) replaced with '<redacted>'.",
            "items": {
              "type": "object",
              "required": ["id", "contract", "contractVersion", "request", "startedAt", "durationMs", "payloadTruncated"],
              "additionalProperties": false,
              "properties": {
                "id": {
                  "type": "string",
                  "description": "Monotonic session-scoped id. Used as the row key."
                },
                "contract": {
                  "type": "string",
                  "description": "Operation name at call time, e.g. plan.create."
                },
                "contractVersion": {
                  "type": "string",
                  "description": "Operation version at call time. Pinned per call."
                },
                "request": {
                  "type": "object",
                  "description": "Sanitized request payload. Sensitive fields and filesystem paths are redacted."
                },
                "response": {
                  "type": "object",
                  "description": "Response payload on success. Absent when the call errored."
                },
                "error": {
                  "type": "object",
                  "required": ["code", "message"],
                  "additionalProperties": false,
                  "properties": {
                    "code": { "type": "string" },
                    "message": { "type": "string" },
                    "details": { "type": "object" }
                  },
                  "description": "Error envelope on failure. Absent on success."
                },
                "startedAt": {
                  "type": "string",
                  "format": "date-time",
                  "description": "Wall-clock UTC start time."
                },
                "durationMs": {
                  "type": "number",
                  "minimum": 0,
                  "description": "Monotonic elapsed time in milliseconds from dispatch to response or error."
                },
                "payloadTruncated": {
                  "type": "boolean",
                  "description": "True when the recorder truncated the stored request or response above the 64 KB threshold."
                }
              }
            }
          }
        }
      },
      {
        "type": "object",
        "required": ["status", "requestId", "contractVersion", "errors"],
        "additionalProperties": false,
        "properties": {
          "status": { "type": "string", "const": "error" },
          "requestId": { "type": "string" },
          "contractVersion": { "type": "string", "const": "1.0.0" },
          "errors": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["code", "message"],
              "additionalProperties": false,
              "properties": {
                "code": { "type": "string" },
                "message": { "type": "string" },
                "details": { "type": "object" }
              }
            }
          }
        }
      }
    ]
  },
  "errorCodes": [
    {
      "code": "dev_mode.disabled",
      "message": "Developer mode is disabled. The recording proxy is not installed; no calls are available.",
      "httpStatusEquivalent": 403
    }
  ]
}
